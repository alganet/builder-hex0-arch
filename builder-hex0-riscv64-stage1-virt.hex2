#
# Builder-hex0 RISC-V 64-bit Stage 1 (512 bytes)
#
# Board-specific hex0 compiler bootloader for QEMU virt.
# Loaded at 0x80200000 by OpenSBI (a0=hartid, a1=dtb_ptr).
# Reads hex0 source from disk sector 0, compiles to binary at 0x80210000,
# jumps there with a0 = next disk sector, a1 = DTB pointer.
#
# Registers:
#   s0 = hex state (0=first nibble, 1=have first)
#   s1 = current disk sector
#   s2 = offset in buffer (0-511, init 512 to force read)
#   s3 = VirtIO MMIO base
#   s4 = VirtIO struct base (0x80500000)
#   s5 = output write pointer
#   s6 = high nibble accumulator
#   s7 = sector buffer (s4+0x3000)
#   s8 = DTB pointer (from OpenSBI a1)
#   s9 = saved ra in next_byte

:_start
.000C0000 .00800500 13000000  # mv s8, a1
.80020000 .00000054 37000000  # lui t0, 0x54000
.00010000 .00800200 .00001000 13100000  # slli sp, t0, 1
.80020000 .00002840 37000000  # lui t0, 0x40280
.000A0000 .00800200 .00001000 13100000  # slli s4, t0, 1

# Scan MMIO 0x10001000..0x10008000 for VirtIO block device
.80090000 .00100010 37000000  # lui s3, 0x10001
:scan
.80020000 .00800900 .00000000 03200000  # lw t0, 0(s3)
.00030000 .00707274 37000000  # lui t1, 0x74727
.00030000 .00000300 .00006097 13000000  # addi t1, t1, -1674
.00800200 .00006000 @scan_next 63100000  # bne t0, t1, scan_next
.80020000 .00800900 .00008000 03200000  # lw t0, 8(s3)
.00030000 .00002000 13000000  # li t1, 2
.00800200 .00006000 @found 63000000  # beq t0, t1, found
:scan_next
.80020000 .00100000 37000000  # lui t0, 1
.80090000 .00800900 .00005000 33000000  # add s3, s3, t0
.00030000 .00900010 37000000  # lui t1, 0x10009
.00800900 .00006000 @scan 63100000  # bne s3, t1, scan
:halt
$halt 6F000000  # j halt

:found
# Legacy VirtIO v1 init (device starts in reset state)
.80020000 .00003000 13000000  # li t0, 3
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)
.80020000 .00100000 37000000  # lui t0, 1
.00800900 .00005000 .00040002 23200000  # sw t0, 0x28(s3)
.00800900 .00005000 .000E0002 23200000  # sw t0, 0x3C(s3)
.80020000 .00008000 13000000  # li t0, 8
.00800900 .00005000 .000C0002 23200000  # sw t0, 0x38(s3)
.80020000 .00000A00 .0000C000 13500000  # srli t0, s4, 12
.00800900 .00005000 .00000004 23200000  # sw t0, 0x40(s3)
.80020000 .00007000 13000000  # li t0, 7
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

# s7 = sector buffer at s4+0x3000
.80020000 .00300000 37000000  # lui t0, 3
.800B0000 .00000A00 .00005000 33000000  # add s7, s4, t0

# Init compiler state
.80020000 .00801040 37000000  # lui t0, 0x40108
.800A0000 .00800200 .00001000 13100000  # slli s5, t0, 1
.00040000 .00000000 13000000  # li s0, 0
.80040000 .00000000 13000000  # li s1, 0
.00090000 .00000020 13000000  # li s2, 512

# --- Hex0 main loop ---
:hex0_loop
.80000000 $next_byte 6F000000  # jal ra, next_byte
.00800200 @hex0_done 63000000  # beqz t0, hex0_done
# Whitespace: anything <= 0x20
.00030000 .00001002 13000000  # li t1, 0x21
.00800200 .00006000 @hex0_loop 63400000  # blt t0, t1, hex0_loop
# Comments
.00030000 .00003002 13000000  # li t1, 0x23
.00800200 .00006000 @skip_comment 63000000  # beq t0, t1, skip_comment
.00030000 .0000B003 13000000  # li t1, 0x3B
.00800200 .00006000 @skip_comment 63000000  # beq t0, t1, skip_comment
# Force uppercase: if >= 'a', subtract 0x20
.00030000 .00001006 13000000  # li t1, 0x61
.00800200 .00006000 @no_lower 63400000  # blt t0, t1, no_lower
.80020000 .00800200 .000000FE 13000000  # addi t0, t0, -0x20
:no_lower
# Parse hex: '0'-'9' then 'A'-'F'
.00030000 .00800200 .000000FD 13000000  # addi t1, t0, -0x30
.00000300 @hex0_loop 63400000  # bltz t1, hex0_loop
.80030000 .0000A000 13000000  # li t2, 10
.00000300 .00007000 @got_nibble 63400000  # blt t1, t2, got_nibble
.00030000 .00000300 .0000F0FE 13000000  # addi t1, t1, -17
.80030000 .00006000 13000000  # li t2, 6
.00000300 .00007000 @hex0_loop 63700000  # bgeu t1, t2, hex0_loop
.00030000 .00000300 .0000A000 13000000  # addi t1, t1, 10
:got_nibble
# t1 = nibble (0-15)
.00000400 @second_nibble 63100000  # bnez s0, second_nibble
.000B0000 .00000300 .00004000 13100000  # slli s6, t1, 4
.00040000 .00001000 13000000  # li s0, 1
$hex0_loop 6F000000  # j hex0_loop
:second_nibble
.00030000 .00000B00 .00006000 33600000  # or t1, s6, t1
.00800A00 .00006000 .00000000 23000000  # sb t1, 0(s5)
.800A0000 .00800A00 .00001000 13000000  # addi s5, s5, 1
.00040000 .00000000 13000000  # li s0, 0
$hex0_loop 6F000000  # j hex0_loop

:skip_comment
.80000000 $next_byte 6F000000  # jal ra, next_byte
.00800200 @hex0_done 63000000  # beqz t0, hex0_done
.00030000 .0000A000 13000000  # li t1, 0x0A
.00800200 .00006000 @skip_comment 63100000  # bne t0, t1, skip_comment
$hex0_loop 6F000000  # j hex0_loop

:hex0_done
.00050000 .00800400 13000000  # mv a0, s1
.80050000 .00000C00 13000000  # mv a1, s8
.80020000 .00801040 37000000  # lui t0, 0x40108
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00000000 .00800200 .00000000 67000000  # jalr zero, t0, 0

# --- next_byte: return next byte in t0 ---
:next_byte
.80020000 .00000020 13000000  # li t0, 512
.00000900 .00005000 @nb_ready 63400000  # blt s2, t0, nb_ready
.800C0000 .00800000 13000000  # mv s9, ra
.80000000 $read_sector 6F000000  # jal ra, read_sector
.80000000 .00800C00 13000000  # mv ra, s9
.80040000 .00800400 .00001000 13000000  # addi s1, s1, 1
.00090000 .00000000 13000000  # li s2, 0
:nb_ready
.80020000 .00800B00 .00002001 33000000  # add t0, s7, s2
.80020000 .00800200 .00000000 03400000  # lbu t0, 0(t0)
.00090000 .00000900 .00001000 13000000  # addi s2, s2, 1
67800000  # ret

# --- read_sector: read sector s1 via VirtIO into s7 ---
# Descriptors set up fresh each call. Uses s3, s4, s7.
:read_sector
# Header at s4+0x2000
.80030000 .00200000 37000000  # lui t2, 2
.80030000 .00000A00 .00007000 33000000  # add t2, s4, t2
.00800300 .00009000 .00040000 23300000  # sd s1, 8(t2)

# Descriptor 0: header (s4+0x2000, 16B, NEXT, next=1)
.00000A00 .00007000 .00000000 23300000  # sd t2, 0(s4)
.80020000 .00000001 13000000  # li t0, 16
.00000A00 .00005000 .00040000 23200000  # sw t0, 8(s4)
.80020000 .00001000 13000000  # li t0, 1
.00000A00 .00005000 .00060000 23100000  # sh t0, 12(s4)
.00000A00 .00005000 .00070000 23100000  # sh t0, 14(s4)

# Descriptor 1: data (s7, 512B, NEXT|WRITE, next=2)
.00000A00 .00007001 .00080000 23300000  # sd s7, 16(s4)
.80020000 .00000020 13000000  # li t0, 512
.00000A00 .00005000 .000C0000 23200000  # sw t0, 24(s4)
.80020000 .00003000 13000000  # li t0, 3
.00000A00 .00005000 .000E0000 23100000  # sh t0, 28(s4)
.80020000 .00002000 13000000  # li t0, 2
.00000A00 .00005000 .000F0000 23100000  # sh t0, 30(s4)

# Descriptor 2: status (s4+0x2010, 1B, WRITE)
.80020000 .00800300 .00000001 13000000  # addi t0, t2, 0x10
.00000A00 .00005000 .00000002 23300000  # sd t0, 32(s4)
.80020000 .00001000 13000000  # li t0, 1
.00000A00 .00005000 .00040002 23200000  # sw t0, 40(s4)
.80020000 .00002000 13000000  # li t0, 2
.00000A00 .00005000 .00060002 23100000  # sh t0, 44(s4)
.00000A00 .00000000 .00070002 23100000  # sh zero, 46(s4)

# Save used.idx, update avail ring
.80020000 .00100000 37000000  # lui t0, 1
.80020000 .00000A00 .00005000 33000000  # add t0, s4, t0
.00030000 .00800200 .00002000 03500000  # lhu t1, 2(t0)
.80020000 .00000A00 .00000008 13000000  # addi t0, s4, 0x80
.00050000 .00800200 .00002000 03500000  # lhu a0, 2(t0)
.80030000 .00000500 .00007000 13700000  # andi t2, a0, 7
.80030000 .00800300 .00001000 13100000  # slli t2, t2, 1
.80030000 .00800300 .00004000 13000000  # addi t2, t2, 4
.80030000 .00800200 .00007000 33000000  # add t2, t0, t2
.00800300 .00000000 .00000000 23100000  # sh zero, 0(t2)
.00050000 .00000500 .00001000 13000000  # addi a0, a0, 1
.00800200 .0000A000 .00010000 23100000  # sh a0, 2(t0)

0F00F00F  # fence
.00800900 .00000000 .00080004 23200000  # sw zero, 0x50(s3)

.80020000 .00100000 37000000  # lui t0, 1
.80020000 .00000A00 .00005000 33000000  # add t0, s4, t0
:rs_poll
0F00F00F  # fence
.00050000 .00800200 .00002000 03500000  # lhu a0, 2(t0)
.00000500 .00006000 @rs_poll 63000000  # beq a0, t1, rs_poll
67800000  # ret
