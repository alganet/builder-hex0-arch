4B010054  # b.lt rsb_have_data

    ; Read next sector into stdin buffer at 0x60010000
201940F9  # ldr x0, [x9, #0x30] # sector number
2100ACD2  # movz x1, #0x6001, lsl #16 # buffer = 0x60010000
B4010094  # bl disk_read_sector

    ; Advance sector, reset offset
0906A8D2  # movz x9, #0x4030, lsl #16
2A1940F9  # ldr x10, [x9, #0x30]
4A050091  # add x10, x10, #1
2A1900F9  # str x10, [x9, #0x30] # stdin_sector++
3F1D00F9  # str xzr, [x9, #0x38] # stdin_offset = 0
0A0080D2  # mov x10, #0

:rsb_have_data
