;============================================================
; syscall_clone: clone/fork simulation
; Saves parent state, returns 0 (as child). Parent resumes
; when child calls exit, returning 1.
;============================================================
:syscall_clone
    ; Get current process descriptor
FA010094  # bl get_process_base
F50300AA  # mov x21, x0 # x21 = proc base

    ; Save brk to saved_brk (+0x28)
0906A8D2  # movz x9, #0x4030, lsl #16
2A2140F9  # ldr x10, [x9, #0x40] # current brk (PA)
AA1600F9  # str x10, [x21, #0x28] # saved_brk

    ; Save kernel sp to saved_stack_pointer_fork (+0x18)
E9030091  # mov x9, sp
A90E00F9  # str x9, [x21, #0x18]

    ; Set forked flag (+0x20)
A91240F9  # ldr x9, [x21, #0x20]
29050091  # add x9, x9, #1
A91200F9  # str x9, [x21, #0x20]

    ; Save stack: copy from sp to kernel_stack_top (0x68000000)
0900ADD2  # movz x9, #0x6800, lsl #16 # x9 = 0x68000000 (stack top)
EA030091  # mov x10, sp # x10 = current sp (can't use sp directly in sub reg)
2A010ACB  # sub x10, x9, x10 # x10 = stack length

    ; Get save address from next_save_process_address
0906A8D2  # movz x9, #0x4030, lsl #16
361540F9  # ldr x22, [x9, #0x28] # next_save_process_address
B62600F9  # str x22, [x21, #0x48] # save stack save address

0900ADD2  # movz x9, #0x6800, lsl #16
EA030091  # mov x10, sp
2A010ACB  # sub x10, x9, x10 # stack length
AA2A00F9  # str x10, [x21, #0x50] # save stack length

    ; Copy stack to save area
E00316AA  # mov x0, x22 # dest = save area
E1030091  # mov x1, sp # src = current sp
E2030AAA  # mov x2, x10 # len
96010094  # bl memcpy

    ; Advance next_save_process_address
0906A8D2  # movz x9, #0x4030, lsl #16
2A1540F9  # ldr x10, [x9, #0x28]
AB2A40F9  # ldr x11, [x21, #0x50] # stack length
4A010B8B  # add x10, x10, x11
2A1500F9  # str x10, [x9, #0x28]

    ; Save process memory: from process_address to brk
B70240F9  # ldr x23, [x21, #0] # process_address (PA)
0906A8D2  # movz x9, #0x4030, lsl #16
382140F9  # ldr x24, [x9, #0x40] # brk (PA)
0A0317CB  # sub x10, x24, x23 # process memory length

    ; Get save address
0906A8D2  # movz x9, #0x4030, lsl #16
391540F9  # ldr x25, [x9, #0x28] # next save addr
B91E00F9  # str x25, [x21, #0x38] # saved_process_mem_addr

020317CB  # sub x2, x24, x23 # length
A22200F9  # str x2, [x21, #0x40] # saved_process_mem_len

    ; Copy process memory
E00319AA  # mov x0, x25 # dest
E10317AA  # mov x1, x23 # src = process_address (PA)
85010094  # bl memcpy

    ; Advance next_save_process_address
0906A8D2  # movz x9, #0x4030, lsl #16
2A1540F9  # ldr x10, [x9, #0x28]
AB2240F9  # ldr x11, [x21, #0x40] # process mem length
4A010B8B  # add x10, x10, x11
2A1500F9  # str x10, [x9, #0x28]

    ; Save user stack: from MIN(SP_EL0, x18) PA to 0x50000000
    ; M2-Planet uses x18 as data stack pointer which diverges from SP_EL0.
    ; We must save the entire range that either stack uses.
