;============================================================
; main: Boot sequence
;============================================================
:main
    ; Use SP_EL1 for kernel, then set it
BF4100D5  # msr spsel, #1
DF3F03D5  # isb
0900ADD2  # movz x9, #0x6800, lsl #16
3F010091  # mov sp, x9 # SP_EL1 = 0x68000000

    ; Save x0 = stdin_sector and x1 = DTB pointer
F80300AA  # mov x24, x0
F90301AA  # mov x25, x1

    ; Load RAM base into x20
2EFBFF97  # bl load_ram_base

    ; Set up exception vector table
A9AFFE10  # adr x9, exception_vectors
09C018D5  # msr vbar_el1, x9

    ; Disable all EL1 interrupts
DF4F03D5  # msr daifset, #0xF

    ; Parse device tree
E00319AA  # mov x0, x25
20FCFF97  # bl fdt_find_storage

3F0400F1  # cmp x1, #1
80000054  # b.eq init_virtio
3F0800F1  # cmp x1, #2
80000054  # b.eq init_spi_sd
28FBFF17  # b reboot

:init_virtio
A7FCFF97  # bl virtio_init
02000014  # b storage_ready

:init_spi_sd
C6FDFF97  # bl spi_sd_init

:storage_ready

    ; Initialize global data
0906A8D2  # movz x9, #0x4030, lsl #16

6A0080D2  # mov x10, #3
2A0900F9  # str x10, [x9, #0x10]

0A80B2D2  # movz x10, #0x9400, lsl #16
2A0D00F9  # str x10, [x9, #0x18]

2A0080D2  # mov x10, #1
2A1100F9  # str x10, [x9, #0x20]

0A00AED2  # movz x10, #0x7000, lsl #16
2A1500F9  # str x10, [x9, #0x28]

3F2500F9  # str xzr, [x9, #0x48]
3F2900F9  # str xzr, [x9, #0x50]

394100F9  # str x25, [x9, #0x80]

0A0EA8D2  # movz x10, #0x4070, lsl #16
2A2100F9  # str x10, [x9, #0x40]

381900F9  # str x24, [x9, #0x30]
0A4080D2  # mov x10, #512
2A1D00F9  # str x10, [x9, #0x38]

    ; Zero process descriptors (64KB at 0x60400000)
0008ACD2  # movz x0, #0x6040, lsl #16
010280D2  # movz x1, #0x10, lsl #12
16FBFF97  # bl memset_zero

    ; Zero file names area (8MB at 0x60020000)
4000ACD2  # movz x0, #0x6002, lsl #16
0110A0D2  # movz x1, #0x80, lsl #16
13FBFF97  # bl memset_zero

    ; Zero file descriptors area (512KB at 0x60820000)
4010ACD2  # movz x0, #0x6082, lsl #16
0101A0D2  # movz x1, #0x8, lsl #16
10FBFF97  # bl memset_zero

    ; Set process 0 current_dir = "/"
0908ACD2  # movz x9, #0x6040, lsl #16
EA0580D2  # mov w10, #0x2F
2A010439  # strb w10, [x9, #0x100]
3F050439  # strb wzr, [x9, #0x101]
    ; Process 1
0A0082D2  # movz x10, #0x1000
29010A8B  # add x9, x9, x10
EA0580D2  # mov w10, #0x2F
2A010439  # strb w10, [x9, #0x100]
3F050439  # strb wzr, [x9, #0x101]

    ; Set up page table
33FBFF97  # bl setup_page_table

    ; Enable MMU (stays on forever)
A90082D2  # movz x9, #0x1005 # M=1, C=1, I=1
091018D5  # msr sctlr_el1, x9
DF3F03D5  # isb

    ; Jump to internal shell
EAFDFF17  # b internalshell
