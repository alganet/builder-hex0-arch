00040091  # add x0, x0, #1
21040091  # add x1, x1, #1
F9FFFF17  # b strcmp
:strcmp_equal
000080D2  # mov x0, #0
C0035FD6  # ret
:strcmp_diff
20010ACB  # sub x0, x9, x10
C0035FD6  # ret

