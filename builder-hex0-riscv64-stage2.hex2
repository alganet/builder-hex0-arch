#============================================================
# setup_page_table: Create Sv39 root page table at PA 0x80100000
# Entry 0: VA 0x00000000-0x3FFFFFFF -> PA 0x80000000 (U|R|W|X|V)
# Entry 2: VA 0x80000000-0xBFFFFFFF -> PA 0x80000000 (R|W|X|V)
# Entry 3: VA 0xC0000000-0xFFFFFFFF -> PA 0xC0000000 (R|W|X|V)
# Also computes and stores satp_value in globals
#============================================================
:setup_page_table
.00010000 .00000100 .000080FF 13000000  # addi sp, sp, -8
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)

# Zero page table (4KB at 0x80100000)
.80020000 .00000840 37000000  # lui t0, 0x40080
.00050000 .00800200 .00001000 13100000  # slli a0, t0, 1
.80050000 .00100000 37000000  # lui a1, 1
.80000000 $memset_zero 6F000000  # call memset_zero

# Page table entry format (Sv39 gigapage):
# PPN[53:10] = PA >> 30 << 28 (for gigapages, PPN[1:0] must be 0)
# Actually: PTE = (PA >> 12) << 10 | flags
# For gigapage: PA must be 1GB aligned, PPN = PA >> 12
# So PTE = (PA >> 2) | flags  ... wait let me think again
#
# Sv39 PTE format: [63:54]=reserved, [53:10]=PPN, [9:8]=RSW, [7:0]=DAGUXWRV
# PPN = phys_addr >> 12  (page number)
# PTE = PPN << 10 | flags
# For PA=0x80000000: PPN = 0x80000000 >> 12 = 0x80000
# PTE = 0x80000 << 10 | flags = 0x20000000 | flags
#
# Entry 0: PA=0x80000000, flags=U|X|W|R|V = 0b00011111 = 0x1F
# PTE = 0x20000000 | 0x1F = 0x2000001F
.00030000 .00000840 37000000  # lui t1, 0x40080
.00050000 .00000300 .00001000 13100000  # slli a0, t1, 1
.80020000 .00000020 37000000  # lui t0, 0x20000
.80020000 .00800200 .0000F001 13000000  # addi t0, t0, 0x1F
.00000500 .00005000 .00000000 23300000  # sd t0, 0(a0)

# Entry 2: PA=0x80000000, flags=X|W|R|V = 0b00001111 = 0x0F (no U bit)
# PTE = 0x20000000 | 0x0F = 0x2000000F
.80020000 .00000020 37000000  # lui t0, 0x20000
.80020000 .00800200 .0000F000 13000000  # addi t0, t0, 0x0F
.00000500 .00005000 .00080000 23300000  # sd t0, 16(a0)

# Entry 3: PA=0xC0000000, flags=X|W|R|V = 0x0F
# PPN = 0xC0000000 >> 12 = 0xC0000
# PTE = 0xC0000 << 10 | 0x0F = 0x30000000 | 0x0F = 0x3000000F
.80020000 .00000030 37000000  # lui t0, 0x30000
.80020000 .00800200 .0000F000 13000000  # addi t0, t0, 0x0F
.00000500 .00005000 .000C0000 23300000  # sd t0, 24(a0)

# Compute satp value: mode=8 (Sv39) << 60 | PPN(page_table)
# PPN = 0x80100000 >> 12 = 0x80100
# satp = (8 << 60) | 0x80100
.80020000 .00008000 13000000  # li t0, 8
.80020000 .00800200 .0000C003 13100000  # slli t0, t0, 60
.00030000 .00000800 37000000  # lui t1, 0x80
.00030000 .00000300 .00000010 13000000  # addi t1, t1, 0x100
.80020000 .00800200 .00006000 33600000  # or t0, t0, t1

# Store in globals at +0x78
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00000300 .00005000 .000C0006 23300000  # sd t0, 0x78(t1)

.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00010000 .00000100 .00008000 13000000  # addi sp, sp, 8
67800000  # ret

#============================================================
