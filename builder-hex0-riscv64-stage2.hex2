#============================================================
# reboot: SBI SRST cold reboot (via OpenSBI)
# Uses COLD_REBOOT (type 1) instead of SHUTDOWN (type 0) because:
# - All boards have a reboot device (not all have a shutdown device)
# - Reboot is the correct semantic for bootstrapping (boot -> build -> reboot)
# - Tests use --no-reboot so QEMU exits cleanly on reboot
#============================================================
:reboot
.80080000 .00505253 37000000  # lui a7, 0x53525
.80080000 .00800800 .00004035 13000000  # addi a7, a7, 0x354
.00080000 .00000000 13000000  # li a6, 0
.00050000 .00001000 13000000  # li a0, 1
.80050000 .00000000 13000000  # li a1, 0
73000000  # ecall
:reboot_hang
$reboot_hang 6F000000  # j reboot_hang

#============================================================
# memset_zero: Zero memory from a0 to a0+a1
# a0 = start address, a1 = byte count (must be multiple of 8)
#============================================================
:memset_zero
.00800500 @memset_done 63000000  # beqz a1, memset_done
.00000500 .00000000 .00000000 23300000  # sd zero, 0(a0)
.00050000 .00000500 .00008000 13000000  # addi a0, a0, 8
.80050000 .00800500 .000080FF 13000000  # addi a1, a1, -8
$memset_zero 6F000000  # j memset_zero
:memset_done
67800000  # ret

#============================================================
# memcpy: Copy memory
# a0 = dest, a1 = src, a2 = byte count
# Returns: a0 = dest (preserved)
#============================================================
:memcpy
.80020000 .00000500 13000000  # mv t0, a0
:memcpy_loop
.00000600 @memcpy_done 63000000  # beqz a2, memcpy_done
.00030000 .00800500 .00000000 03400000  # lbu t1, 0(a1)
.00000500 .00006000 .00000000 23000000  # sb t1, 0(a0)
.00050000 .00000500 .00001000 13000000  # addi a0, a0, 1
.80050000 .00800500 .00001000 13000000  # addi a1, a1, 1
.00060000 .00000600 .0000F0FF 13000000  # addi a2, a2, -1
$memcpy_loop 6F000000  # j memcpy_loop
:memcpy_done
.00050000 .00800200 13000000  # mv a0, t0
67800000  # ret

#============================================================
# bswap32: Byte-swap a 32-bit value (big-endian <-> little-endian)
# a0 = input value (only low 32 bits used)
# Returns: a0 = byte-swapped value (zero-extended to 64 bits)
#============================================================
:bswap32
# Extract bytes and reassemble in reversed order
# Input:  a0 = [B3 B2 B1 B0] (low 32 bits)
# Output: a0 = [B0 B1 B2 B3]
.80020000 .00000500 .0000F00F 13700000  # andi t0, a0, 0xFF
.80020000 .00800200 .00008001 13100000  # slli t0, t0, 24
.00030000 .00000500 .00008000 13500000  # srli t1, a0, 8
.00030000 .00000300 .0000F00F 13700000  # andi t1, t1, 0xFF
.00030000 .00000300 .00000001 13100000  # slli t1, t1, 16
.80020000 .00800200 .00006000 33600000  # or t0, t0, t1
.00030000 .00000500 .00000001 13500000  # srli t1, a0, 16
.00030000 .00000300 .0000F00F 13700000  # andi t1, t1, 0xFF
.00030000 .00000300 .00008000 13100000  # slli t1, t1, 8
.80020000 .00800200 .00006000 33600000  # or t0, t0, t1
.00030000 .00000500 .00008001 13500000  # srli t1, a0, 24
.00030000 .00000300 .0000F00F 13700000  # andi t1, t1, 0xFF
.00050000 .00800200 .00006000 33600000  # or a0, t0, t1
67800000  # ret

#============================================================
# read_stdin_byte: Read one byte from stdin (disk via VirtIO)
# Uses globals: stdin_sector (+0x30), stdin_offset (+0x38)
# Returns: a0 = byte read
# Called from S-mode (internal shell), paging OFF
#============================================================
:read_stdin_byte
.00010000 .00000100 .000000FF 13000000  # addi sp, sp, -16
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)

# Load global data base
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008003 03300000  # ld t1, 0x38(t0)

# If offset >= 512, read next sector
.80030000 .00000020 13000000  # li t2, 512
.00000300 .00007000 @rsb_have_data 63400000  # blt t1, t2, rsb_have_data

# Read next sector into stdin buffer at 0xA0010000
.00050000 .00800200 .00000003 03300000  # ld a0, 0x30(t0)
.80050000 .00800050 37000000  # lui a1, 0x50008
.80050000 .00800500 .00001000 13100000  # slli a1, a1, 1
.80000000 $disk_read_sector 6F000000  # call disk_read_sector

# Advance sector, reset offset
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00000003 03300000  # ld t1, 0x30(t0)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.00800200 .00006000 .00080002 23300000  # sd t1, 0x30(t0)
.00800200 .00000000 .000C0002 23300000  # sd zero, 0x38(t0)
.00030000 .00000000 13000000  # li t1, 0

:rsb_have_data
