.80020000 .00800200 .0000F0FF 13000000  # addi t0, t0, -1
.00030000 .00800200 .00003000 13100000  # slli t1, t0, 3
.00030000 .00000E00 .00006000 33000000  # add t1, t3, t1
.00030000 .00000300 .00000000 03300000  # ld t1, 0(t1)
.000C0000 .00000C00 .000080FF 13000000  # addi s8, s8, -8
.00000C00 .00006000 .00000000 23300000  # sd t1, 0(s8)
$execve_push_argv 6F000000  # j execve_push_argv

:execve_push_argc
# Push argc
.000C0000 .00000C00 .000080FF 13000000  # addi s8, s8, -8
.00000C00 .00006001 .00000000 23300000  # sd s6, 0(s8)

# Now s8 = user stack PA. Calculate VA = s8 - 0x80000000
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000C0000 .00000C00 .00005000 33000040  # sub s8, s8, t0

