#============================================================
# fdt_find_storage: Parse FDT to find storage device
# a0 = DTB pointer (from OpenSBI via stage 1)
# Returns: a0 = MMIO base address (0 if not found)
#          a1 = storage type (0=none, 1=virtio, 2=spi_sd)
#
# Single-pass DTB walk. Detects:
# - VirtIO: node name starts with "virt", reg property gives MMIO base,
#   probed for VirtIO magic (0x74726976) and block device ID (2)
# - SPI+SD: node name starts with "spi@" (saves reg as SPI base),
#   child node name starts with "mmc@" (confirms SD card present)
#
# No fallback — returns what the DTB describes.
# FDT is big-endian; uses bswap32 for all multi-byte fields.
#============================================================
:fdt_find_storage
.00010000 .00000100 .000000FA 13000000  # addi sp, sp, -96
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00009000 .00080000 23300000  # sd s1, 16(sp)
.00000100 .00003001 .000C0000 23300000  # sd s3, 24(sp)
.00000100 .00004001 .00000002 23300000  # sd s4, 32(sp)
.00000100 .00005001 .00040002 23300000  # sd s5, 40(sp)
.00000100 .00006001 .00080002 23300000  # sd s6, 48(sp)
.00000100 .00008001 .000C0002 23300000  # sd s8, 56(sp)
.00000100 .00009001 .00000004 23300000  # sd s9, 64(sp)
.00000100 .0000A001 .00040004 23300000  # sd s10, 72(sp)
.00000100 .0000B001 .00080004 23300000  # sd s11, 80(sp)

.00000500 @fdt_not_found 63000000  # beqz a0, fdt_not_found
.00040000 .00000500 13000000  # mv s0, a0

# Validate FDT magic: 0xd00dfeed big-endian = 0xedfe0dd0 as LE lw
.80020000 .00000400 .00000000 03200000  # lw t0, 0(s0)
.00030000 .0010FEED 37000000  # lui t1, 0xedfe1
.00030000 .00000300 .000000DD 13000000  # addi t1, t1, -560
.00800200 .00006000 @fdt_not_found 63100000  # bne t0, t1, fdt_not_found

# Get structure block offset (big-endian u32 at dtb+8)
.00050000 .00000400 .00008000 03200000  # lw a0, 8(s0)
.80000000 $bswap32 6F000000  # call bswap32
.80040000 .00000400 .0000A000 33000000  # add s1, s0, a0

# Get strings block offset (big-endian u32 at dtb+0xC)
.00050000 .00000400 .0000C000 03200000  # lw a0, 0xC(s0)
.80000000 $bswap32 6F000000  # call bswap32
.80090000 .00000400 .0000A000 33000000  # add s3, s0, a0

.000A0000 .00000000 13000000  # li s4, 0
.800A0000 .00000000 13000000  # li s5, 0
.000D0000 .00000000 13000000  # li s10, 0
.800D0000 .00000000 13000000  # li s11, 0

:fdt_walk
.00050000 .00800400 .00000000 03200000  # lw a0, 0(s1)
.80000000 $bswap32 6F000000  # call bswap32
.800C0000 .00000500 13000000  # mv s9, a0
.80040000 .00800400 .00004000 13000000  # addi s1, s1, 4

# FDT_END (9)
.80020000 .00009000 13000000  # li t0, 9
.00800C00 .00005000 @fdt_walk_done 63000000  # beq s9, t0, fdt_walk_done

# FDT_BEGIN_NODE (1)
.80020000 .00001000 13000000  # li t0, 1
.00800C00 .00005000 @fdt_begin_node 63000000  # beq s9, t0, fdt_begin_node

# FDT_END_NODE (2)
.80020000 .00002000 13000000  # li t0, 2
.00800C00 .00005000 @fdt_end_node 63000000  # beq s9, t0, fdt_end_node

# FDT_PROP (3)
.80020000 .00003000 13000000  # li t0, 3
.00800C00 .00005000 @fdt_prop 63000000  # beq s9, t0, fdt_prop

# NOP (4) or unknown: skip
