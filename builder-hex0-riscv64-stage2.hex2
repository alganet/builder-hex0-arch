#============================================================
# virtio_init: Initialize VirtIO block device at given MMIO base
# a0 = MMIO base address (from fdt_find_storage)
# Halts if a0 == 0. Stores MMIO base, struct base, and disk
# function pointers in global data.
#============================================================
:virtio_init
.00010000 .00000100 .000000FD 13000000  # addi sp, sp, -48
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00003001 .00080000 23300000  # sd s3, 16(sp)
.00000100 .00004001 .000C0000 23300000  # sd s4, 24(sp)
.00000100 .00005001 .00000002 23300000  # sd s5, 32(sp)

# a0 = MMIO base from fdt_find_storage; halt if 0
.00000500 @virtio_init_fail 63000000  # beqz a0, virtio_init_fail
.80090000 .00000500 13000000  # mv s3, a0

# Load VirtIO structures base: s4 = 0x80500000
.80020000 .00002840 37000000  # lui t0, 0x40280
.000A0000 .00800200 .00001000 13100000  # slli s4, t0, 1

# Load global data base: s5 = 0x80300000
.80020000 .00001840 37000000  # lui t0, 0x40180
.800A0000 .00800200 .00001000 13100000  # slli s5, t0, 1
# Reset device
.00800900 .00000000 .00080006 23200000  # sw zero, 0x70(s3)

# Set ACKNOWLEDGE
.80020000 .00001000 13000000  # li t0, 1
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

# Set DRIVER
.80020000 .00003000 13000000  # li t0, 3
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

# Check version
.80020000 .00800900 .00004000 03200000  # lw t0, 4(s3)
.00030000 .00002000 13000000  # li t1, 2
.00800200 .00006000 @virtio_modern_setup 63000000  # beq t0, t1, virtio_modern_setup

#--- Version 1 (legacy) setup ---
:virtio_legacy_setup
# Negotiate features: accept none
.00800900 .00000000 .00000002 23200000  # sw zero, 0x20(s3)

# Zero structures area (8KB)
.00050000 .00000A00 13000000  # mv a0, s4
.80050000 .00200000 37000000  # lui a1, 2
.80000000 $memset_zero 6F000000  # call memset_zero

# Set GuestPageSize = 4096 (V1 requirement, offset 0x28)
.80020000 .00100000 37000000  # lui t0, 1
.00800900 .00005000 .00040002 23200000  # sw t0, 0x28(s3)

# Select queue 0
.00800900 .00000000 .00080002 23200000  # sw zero, 0x30(s3)

# Set queue size = 8
.80020000 .00008000 13000000  # li t0, 8
.00800900 .00005000 .000C0002 23200000  # sw t0, 0x38(s3)

# Set QueueAlign = 4096
.80020000 .00100000 37000000  # lui t0, 1
.00800900 .00005000 .000E0002 23200000  # sw t0, 0x3C(s3)

# Set QueuePFN = 0x80500000 / 4096 = 0x80500
.80020000 .00000800 37000000  # lui t0, 0x80
.80020000 .00800200 .00000050 13000000  # addi t0, t0, 0x500
.00800900 .00005000 .00000004 23200000  # sw t0, 0x40(s3)

# Set DRIVER_OK
.80020000 .00007000 13000000  # li t0, 7
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

$virtio_init_done 6F000000  # j virtio_init_done

#--- Version 2 (modern) setup ---
:virtio_modern_setup
# Accept no features
.00800900 .00000000 .00020002 23200000  # sw zero, 0x24(s3)
.00800900 .00000000 .00000002 23200000  # sw zero, 0x20(s3)

# Set FEATURES_OK: Status = 0xB
.80020000 .0000B000 13000000  # li t0, 0xB
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

# Verify FEATURES_OK persisted
.80020000 .00800900 .00000007 03200000  # lw t0, 0x70(s3)
.80020000 .00800200 .00008000 13700000  # andi t0, t0, 8
.00800200 @reboot 63000000  # beqz t0, reboot

# Zero structures area
.00050000 .00000A00 13000000  # mv a0, s4
.80050000 .00200000 37000000  # lui a1, 2
.80000000 $memset_zero 6F000000  # call memset_zero

# Select queue 0
.00800900 .00000000 .00080002 23200000  # sw zero, 0x30(s3)

# Set queue size = 8
.80020000 .00008000 13000000  # li t0, 8
.00800900 .00005000 .000C0002 23200000  # sw t0, 0x38(s3)

# Descriptor table address = s4
.80020000 .00000A00 13000000  # mv t0, s4
.00800900 .00005000 .00000008 23200000  # sw t0, 0x80(s3)
.80020000 .00000A00 .00000002 13500000  # srli t0, s4, 32
.00800900 .00005000 .00020008 23200000  # sw t0, 0x84(s3)

# Available ring address = s4 + 0x80
.80020000 .00000A00 .00000008 13000000  # addi t0, s4, 0x80
.00800900 .00005000 .00080008 23200000  # sw t0, 0x90(s3)
.00030000 .00000A00 .00000002 13500000  # srli t1, s4, 32
.00800900 .00006000 .000A0008 23200000  # sw t1, 0x94(s3)

# Used ring address = s4 + 0x1000
.80020000 .00100000 37000000  # lui t0, 1
.80020000 .00000A00 .00005000 33000000  # add t0, s4, t0
.00800900 .00005000 .0000000A 23200000  # sw t0, 0xA0(s3)
.00030000 .00000A00 .00000002 13500000  # srli t1, s4, 32
.00800900 .00006000 .0002000A 23200000  # sw t1, 0xA4(s3)

# Enable queue
.80020000 .00001000 13000000  # li t0, 1
.00800900 .00005000 .00020004 23200000  # sw t0, 0x44(s3)

# Set DRIVER_OK (must include FEATURES_OK for V2)
# ACK(1) | DRIVER(2) | FEATURES_OK(8) | DRIVER_OK(4) = 0xF
.80020000 .0000F000 13000000  # li t0, 0xF
.00800900 .00005000 .00080006 23200000  # sw t0, 0x70(s3)

$virtio_init_done 6F000000  # j virtio_init_done

:virtio_init_fail
