#============================================================
# syscall_clone: clone/fork simulation
# Saves parent state, returns 0 (as child). Parent resumes
# when child calls exit, returning 1.
#============================================================
:syscall_clone
# Get current process descriptor
.80000000 $get_process_base 6F000000  # call get_process_base
.80090000 .00000500 13000000  # mv s3, a0

# Save brk to saved_brk (+0x28)
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00000004 03300000  # ld t1, 0x40(t0)
.00800900 .00006000 .00040002 23300000  # sd t1, 0x28(s3)

# Save kernel sp to saved_stack_pointer_fork (+0x18)
# (sp is the kernel stack after trap frame allocation)
.00800900 .00002000 .000C0000 23300000  # sd sp, 0x18(s3)

# Set forked flag (+0x20)
.80020000 .00800900 .00000002 03300000  # ld t0, 0x20(s3)
.80020000 .00800200 .00001000 13000000  # addi t0, t0, 1
.00800900 .00005000 .00000002 23300000  # sd t0, 0x20(s3)

# Save stack: copy from sp to kernel_stack_top (0xA8000000)
.80020000 .00000054 37000000  # lui t0, 0x54000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00002000 33000040  # sub t1, t0, sp

# Get save address from next_save_process_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000A0000 .00800200 .00008002 03300000  # ld s4, 0x28(t0)
.00800900 .00004001 .00040004 23300000  # sd s4, 0x48(s3)

.80020000 .00000054 37000000  # lui t0, 0x54000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00002000 33000040  # sub t1, t0, sp
.00800900 .00006000 .00080004 23300000  # sd t1, 0x50(s3)

# Copy stack to save area
.00050000 .00000A00 13000000  # mv a0, s4
.80050000 .00000100 13000000  # mv a1, sp
.00060000 .00000300 13000000  # mv a2, t1
.80000000 $memcpy 6F000000  # call memcpy

# Advance next_save_process_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008002 03300000  # ld t1, 0x28(t0)
.80030000 .00800900 .00000005 03300000  # ld t2, 0x50(s3)
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2
.00800200 .00006000 .00040002 23300000  # sd t1, 0x28(t0)

# Save process memory: from process_address to brk
.800A0000 .00800900 .00000000 03300000  # ld s5, 0(s3)
.000B0000 .00800900 .00000004 03300000  # ld s6, 0x40(s3)
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000B0000 .00800200 .00000004 03300000  # ld s6, 0x40(t0)
.00030000 .00000B00 .00005001 33000040  # sub t1, s6, s5
.00800900 .00006000 .00000004 23300000  # sd t1, 0x40(s3)
# Actually use dedicated fields: +0x38 = saved_process_mem_addr, +0x40 = saved_process_mem_len
# But +0x40 is brk in the plan... Let me re-check the layout.
# Plan says: +0x038: saved_process_mem_addr, +0x040: saved_process_mem_len
# But brk is in globals at 0x80300040, not in process descriptor.
# So +0x040 in proc descriptor is saved_process_mem_len. OK.

# Get save address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.800B0000 .00800200 .00008002 03300000  # ld s7, 0x28(t0)
.00800900 .00007001 .000C0002 23300000  # sd s7, 0x38(s3)

.00060000 .00000B00 .00005001 33000040  # sub a2, s6, s5
.00800900 .0000C000 .00000004 23300000  # sd a2, 0x40(s3)

# Copy process memory
.00050000 .00800B00 13000000  # mv a0, s7
.80050000 .00800A00 13000000  # mv a1, s5
.80000000 $memcpy 6F000000  # call memcpy

# Advance next_save_process_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008002 03300000  # ld t1, 0x28(t0)
.80030000 .00800900 .00000004 03300000  # ld t2, 0x40(s3)
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2
.00800200 .00006000 .00040002 23300000  # sd t1, 0x28(t0)

# Save user stack: from user sp (PA) to 0x90000000
# User sp is in the trap frame at offset 8
.800A0000 .00000100 .00008000 03300000  # ld s5, 8(sp)
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.800A0000 .00800A00 .00005000 33000000  # add s5, s5, t0

.80020000 .00000048 37000000  # lui t0, 0x48000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000B0000 .00800200 .00005001 33000040  # sub s6, t0, s5

# Get save address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.800B0000 .00800200 .00008002 03300000  # ld s7, 0x28(t0)
.00800900 .00007001 .000C0004 23300000  # sd s7, 0x58(s3)
.00800900 .00006001 .00000006 23300000  # sd s6, 0x60(s3)

# Copy user stack to save area
.00050000 .00800B00 13000000  # mv a0, s7
.80050000 .00800A00 13000000  # mv a1, s5
.00060000 .00000B00 13000000  # mv a2, s6
.80000000 $memcpy 6F000000  # call memcpy

# Advance next_save_process_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008002 03300000  # ld t1, 0x28(t0)
.00030000 .00000300 .00006001 33000000  # add t1, t1, s6
.00800200 .00006000 .00040002 23300000  # sd t1, 0x28(t0)

# Return 0 (child return from fork)
.00000100 .00000000 .00040004 23300000  # sd zero, 72(sp)
$trap_exit 6F000000  # j trap_exit

#============================================================
# syscall_execve: execve(pathname, argv, envp)
# a0(72)=pathname, a1(80)=argv, a2(88)=envp
# Loads 64-bit ELF, sets up process, jumps to entry
#============================================================
:syscall_execve
.80090000 .00000100 .00008004 03300000  # ld s3, 72(sp)
.000A0000 .00000100 .00000005 03300000  # ld s4, 80(sp)
.800A0000 .00000100 .00008005 03300000  # ld s5, 88(sp)

# Translate all pointers VA -> PA
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80090000 .00800900 .00005000 33000000  # add s3, s3, t0
.000A0000 .00000A00 .00005000 33000000  # add s4, s4, t0
.800A0000 .00800A00 .00005000 33000000  # add s5, s5, t0

# Check if current process forked (check BEFORE first-process check)
.80000000 $get_process_base 6F000000  # call get_process_base
.000B0000 .00000500 13000000  # mv s6, a0
.80020000 .00000B00 .00000002 03300000  # ld t0, 0x20(s6)
.00800200 @execve_forked 63100000  # bnez t0, execve_forked

# Not forked: check if first process (direct exec from shell)
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00000002 03300000  # ld t1, 0x20(t0)
.80030000 .00001000 13000000  # li t2, 1
.00000300 .00007000 @execve_overlay 63100000  # bne t1, t2, execve_overlay

# First process: save original sp at proc[1]+0x10
.80020000 .00002040 37000000  # lui t0, 0x40200
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00100000 37000000  # lui t1, 1
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00800200 .00002000 .00080000 23300000  # sd sp, 0x10(t0)
$execve_prepare_stack 6F000000  # j execve_prepare_stack

:execve_forked
# Forked: create new process after fork
# Decrement forked flag
.80020000 .00800200 .0000F0FF 13000000  # addi t0, t0, -1
.00000B00 .00005000 .00000002 23300000  # sd t0, 0x20(s6)
$execve_prepare_stack 6F000000  # j execve_prepare_stack

:execve_overlay
# Not forked, not first: overlay current process (same slot)
$execve_prepare_stack 6F000000  # j execve_prepare_stack

:execve_prepare_stack
# Set up user stack at PA 0x90000000 (VA 0x10000000)
# Push envp strings, then argv strings, then pointers, then argc

# First, count argc
.80020000 .00000A00 13000000  # mv t0, s4
.800B0000 .00000000 13000000  # li s7, 0
# VA range limit: 0x40000000 (1GB, matches page table entry 0)
.80030000 .00000040 37000000  # lui t2, 0x40000
:execve_count_args
.00030000 .00800200 .00000000 03300000  # ld t1, 0(t0)
.00000300 @execve_counted 63000000  # beqz t1, execve_counted
.00000300 .00007000 @execve_counted 63700000  # bgeu t1, t2, execve_counted
.800B0000 .00800B00 .00001000 13000000  # addi s7, s7, 1
.80020000 .00800200 .00008000 13000000  # addi t0, t0, 8
$execve_count_args 6F000000  # j execve_count_args
:execve_counted

# String storage on user stack, growing DOWN from PA 0x90000000.
# This ensures argv/envp strings are within [user_sp, 0x90000000)
# and thus saved/restored by clone, preventing corruption when
# child processes overwrite argv strings during their own execve.
.80020000 .00000048 37000000  # lui t0, 0x48000
.800C0000 .00800200 .00001000 13100000  # slli s9, t0, 1

# ---- Phase 1: Copy argv strings ----
# Temp argv VA array at PA 0xA0001000
.80020000 .00000050 37000000  # lui t0, 0x50000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00100000 37000000  # lui t1, 1
.000D0000 .00800200 .00006000 33000000  # add s10, t0, t1

.800D0000 .00000A00 13000000  # mv s11, s4
.000B0000 .00800B00 13000000  # mv s6, s7
.800B0000 .00000000 13000000  # li s7, 0
:execve_copy_argv
.00800B00 .00006001 @execve_argv_done 63500000  # bge s7, s6, execve_argv_done
.00030000 .00800D00 .00000000 03300000  # ld t1, 0(s11)
.00000300 @execve_argv_done 63000000  # beqz t1, execve_argv_done

# Translate argv[i] VA -> PA
.80030000 .00000040 37000000  # lui t2, 0x40000
.80030000 .00800300 .00001000 13100000  # slli t2, t2, 1
.80050000 .00000300 .00007000 33000000  # add a1, t1, t2

# Allocate string slot on user stack (grow down)
.800C0000 .00800C00 .000000F0 13000000  # addi s9, s9, -256
# Copy string from a1 to s9 (256 bytes max)
.00050000 .00800C00 13000000  # mv a0, s9
.00060000 .00000010 13000000  # li a2, 256
.80000000 $memcpy 6F000000  # call memcpy

# Calculate VA for this string: VA = PA - 0x80000000
.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00030000 .00800C00 .00006000 33000040  # sub t1, s9, t1

# Store VA in temp array
.80030000 .00800B00 .00003000 13100000  # slli t2, s7, 3
.80030000 .00000D00 .00007000 33000000  # add t2, s10, t2
.00800300 .00006000 .00000000 23300000  # sd t1, 0(t2)

.800B0000 .00800B00 .00001000 13000000  # addi s7, s7, 1
.800D0000 .00800D00 .00008000 13000000  # addi s11, s11, 8
$execve_copy_argv 6F000000  # j execve_copy_argv

:execve_argv_done
.000B0000 .00800B00 13000000  # mv s6, s7

# ---- Phase 2: Copy envp strings ----
# Temp envp VA array at PA 0xA0002000
.80020000 .00000050 37000000  # lui t0, 0x50000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00200000 37000000  # lui t1, 2
.000D0000 .00800200 .00006000 33000000  # add s10, t0, t1

.800D0000 .00800A00 13000000  # mv s11, s5
.800B0000 .00000000 13000000  # li s7, 0
:execve_copy_envp
.00030000 .00800D00 .00000000 03300000  # ld t1, 0(s11)
.00000300 @execve_envp_done 63000000  # beqz t1, execve_envp_done
.80030000 .00000040 37000000  # lui t2, 0x40000
.00000300 .00007000 @execve_envp_done 63700000  # bgeu t1, t2, execve_envp_done

# Translate VA -> PA
.80030000 .00000040 37000000  # lui t2, 0x40000
.80030000 .00800300 .00001000 13100000  # slli t2, t2, 1
.80050000 .00000300 .00007000 33000000  # add a1, t1, t2

# Allocate string slot on user stack (grow down)
.800C0000 .00800C00 .000000F0 13000000  # addi s9, s9, -256
.00050000 .00800C00 13000000  # mv a0, s9
.00060000 .00000010 13000000  # li a2, 256
.80000000 $memcpy 6F000000  # call memcpy

.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00030000 .00800C00 .00006000 33000040  # sub t1, s9, t1

.80030000 .00800B00 .00003000 13100000  # slli t2, s7, 3
.80030000 .00000D00 .00007000 33000000  # add t2, s10, t2
.00800300 .00006000 .00000000 23300000  # sd t1, 0(t2)

.800B0000 .00800B00 .00001000 13000000  # addi s7, s7, 1
.800D0000 .00800D00 .00008000 13000000  # addi s11, s11, 8
$execve_copy_envp 6F000000  # j execve_copy_envp

:execve_envp_done
# s6 = argc, s7 = envc
# Save envc to stack for later
.00010000 .00000100 .000080FF 13000000  # addi sp, sp, -8
.00000100 .00007001 .00000000 23300000  # sd s7, 0(sp)

# ---- Phase 3: Build stack ----
# s9 is now below all strings on the user stack.
# Set s8 = s9 so the pointer/argc area grows below the strings.
.000C0000 .00800C00 13000000  # mv s8, s9

# Stack layout (low addr to high addr, sp points to lowest):
#   argc, argv[0]..argv[argc-1], NULL, envp[0]..envp[envc-1], NULL, strings...

# Push NULL (envp terminator)
.000C0000 .00000C00 .000080FF 13000000  # addi s8, s8, -8
.00000C00 .00000000 .00000000 23300000  # sd zero, 0(s8)

# Push envp pointers in reverse order
.80020000 .00000100 .00000000 03300000  # ld t0, 0(sp)
.000E0000 .00000050 37000000  # lui t3, 0x50000
.000E0000 .00000E00 .00001000 13100000  # slli t3, t3, 1
.800E0000 .00200000 37000000  # lui t4, 2
.000E0000 .00000E00 .0000D001 33000000  # add t3, t3, t4
:execve_push_envp
.00800200 @execve_push_envp_done 63000000  # beqz t0, execve_push_envp_done
.80020000 .00800200 .0000F0FF 13000000  # addi t0, t0, -1
.00030000 .00800200 .00003000 13100000  # slli t1, t0, 3
.00030000 .00000E00 .00006000 33000000  # add t1, t3, t1
.00030000 .00000300 .00000000 03300000  # ld t1, 0(t1)
.000C0000 .00000C00 .000080FF 13000000  # addi s8, s8, -8
.00000C00 .00006000 .00000000 23300000  # sd t1, 0(s8)
$execve_push_envp 6F000000  # j execve_push_envp
:execve_push_envp_done
.00010000 .00000100 .00008000 13000000  # addi sp, sp, 8

# Push NULL (argv terminator)
.000C0000 .00000C00 .000080FF 13000000  # addi s8, s8, -8
.00000C00 .00000000 .00000000 23300000  # sd zero, 0(s8)

# Push argv pointers in reverse order
.80020000 .00000B00 13000000  # mv t0, s6
.000E0000 .00000050 37000000  # lui t3, 0x50000
.000E0000 .00000E00 .00001000 13100000  # slli t3, t3, 1
.800E0000 .00100000 37000000  # lui t4, 1
.000E0000 .00000E00 .0000D001 33000000  # add t3, t3, t4
:execve_push_argv
