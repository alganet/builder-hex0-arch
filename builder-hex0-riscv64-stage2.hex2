.800A0000 .00000000 13000000  # li s5, 0

# Check node name prefix (first 4 bytes as LE lw)
.80020000 .00800400 .00000000 03200000  # lw t0, 0(s1)

# "virt" = 0x74726976
.00030000 .00707274 37000000  # lui t1, 0x74727
.00030000 .00000300 .00006097 13000000  # addi t1, t1, -1674
.00800200 .00006000 @fdt_check_spi 63100000  # bne t0, t1, fdt_check_spi
.000A0000 .00001000 13000000  # li s4, 1
