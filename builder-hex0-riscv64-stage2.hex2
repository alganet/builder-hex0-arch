.80020000 .00000B00 .00005000 33000040  # sub t0, s6, t0
.00030000 .00800200 .00000010 13000000  # addi t1, t0, 0x100
.80030000 .00000B00 .00000010 13000000  # addi t2, s6, 0x100
.000E0000 .00000010 13000000  # li t3, 256
:execve_copy_cwd
.00000E00 @execve_cwd_done 63000000  # beqz t3, execve_cwd_done
.800E0000 .00000300 .00000000 03400000  # lbu t4, 0(t1)
.00800300 .0000D001 .00000000 23000000  # sb t4, 0(t2)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.80030000 .00800300 .00001000 13000000  # addi t2, t2, 1
.000E0000 .00000E00 .0000F0FF 13000000  # addi t3, t3, -1
$execve_copy_cwd 6F000000  # j execve_copy_cwd
:execve_cwd_done

# Clear new process open file descriptors
.00050000 .00000B00 .00000020 13000000  # addi a0, s6, 0x200
.80050000 .00100000 37000000  # li a1, 3584 (upper)
.80050000 .00800500 .000000E0 13000000  # li a1, 3584 (lower)
.80000000 $memset_zero 6F000000  # call memset_zero

# Parse 64-bit ELF header
# e_entry at offset 0x18 (8 bytes)
.80090000 .00000D00 .00008001 03300000  # ld s3, 0x18(s10)

# e_phoff at offset 0x20 (8 bytes)
.80020000 .00000D00 .00000002 03300000  # ld t0, 0x20(s10)
.000A0000 .00000D00 .00005000 33000000  # add s4, s10, t0

# e_phnum at offset 0x38 (2 bytes)
.800A0000 .00000D00 .00008003 03500000  # lhu s5, 0x38(s10)


# Zero user process area: 2MB starting at PA 0x80600000
.00050000 .00003040 37000000  # lui a0, 0x40300
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80050000 .00002000 37000000  # lui a1, 0x200
.80000000 $memset_zero 6F000000  # call memset_zero

# Reset brk to process base (will be set properly by phdr loop)
.80020000 .00003040 37000000  # lui t0, 0x40300
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00000300 .00005000 .00000004 23300000  # sd t0, 0x40(t1)

# Load each program header (56 bytes each for ELF64)
# p_type at +0x00 (4 bytes), skip if not PT_LOAD (1)
# p_offset at +0x08 (8 bytes)
# p_vaddr at +0x10 (8 bytes)
# p_filesz at +0x20 (8 bytes)

:execve_load_phdr
.00800A00 @execve_load_done 63000000  # beqz s5, execve_load_done

# Check p_type == PT_LOAD (1)
.80020000 .00000A00 .00000000 03200000  # lw t0, 0(s4)
.00030000 .00001000 13000000  # li t1, 1
.00800200 .00006000 @execve_next_phdr 63100000  # bne t0, t1, execve_next_phdr

.80020000 .00000A00 .00008000 03300000  # ld t0, 0x08(s4)
.80050000 .00000D00 .00005000 33000000  # add a1, s10, t0

.80020000 .00000A00 .00000001 03300000  # ld t0, 0x10(s4)
# Convert VA to PA: PA = VA + 0x80000000
.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00050000 .00800200 .00006000 33000000  # add a0, t0, t1

.00060000 .00000A00 .00000002 03300000  # ld a2, 0x20(s4)
.80000000 $memcpy 6F000000  # call memcpy

# Track end of loaded segments for brk
.80020000 .00000A00 .00000001 03300000  # ld t0, 0x10(s4)
.00030000 .00000A00 .00000002 03300000  # ld t1, 0x20(s4)
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00030000 .00200000 37000000  # lui t1, 2
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1

# Set brk = max across segments (end_of_segment + padding)
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00000300 .00000004 03300000  # ld t2, 0x40(t1)
.00800300 .00005000 @execve_next_phdr 63500000  # bge t2, t0, execve_next_phdr
.00000300 .00005000 .00000004 23300000  # sd t0, 0x40(t1)

:execve_next_phdr
.000A0000 .00000A00 .00008003 13000000  # addi s4, s4, 56
.800A0000 .00800A00 .0000F0FF 13000000  # addi s5, s5, -1
$execve_load_phdr 6F000000  # j execve_load_phdr

:execve_load_done
# Set process_address in descriptor
.80020000 .00003040 37000000  # lui t0, 0x40300
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00000B00 .00005000 .00000000 23300000  # sd t0, 0(s6)

# Clear forked flag
.00000B00 .00000000 .00000002 23300000  # sd zero, 0x20(s6)

# Direct transition to U-mode (like handle_other_command)
# Deallocate trap frame — we won't use trap_exit
.00010000 .00000100 .00000010 13000000  # addi sp, sp, 256

# Ensure new code is visible (I-cache coherence)
0F00F00F  # fence
0F100000  # fence.i

# Clear SPP (bit 8), SPIE (bit 5), and SIE (bit 1) in sstatus
# This prevents interrupts from firing after sret
.80020000 .00002012 13000000  # li t0, 0x122
.00000000 .00800200 .00000010 73300000  # csrrc zero, sstatus, t0

# Set sepc = entry point VA
.00000000 .00800900 .00001014 73100000  # csrrw zero, sepc, s3

# Set sscratch = sp (current kernel stack pointer)
.00000000 .00000100 .00000014 73100000  # csrrw zero, sscratch, sp

# Enable paging
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00800200 .00008007 03300000  # ld t0, 0x78(t0)
.00000000 .00800200 .00000018 73100000  # csrrw zero, satp, t0
73000012  # sfence.vma

# Set sp = user stack VA and sret
.00010000 .00000C00 13000000  # mv sp, s8
73002010  # sret

:execve_fail
.80020000 .0000F0FF 13000000  # li t0, -1
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$trap_exit 6F000000  # j trap_exit

#============================================================
# syscall_exit: exit(code)
# a0(72)=exit code
# Restores parent process or returns to shell
#============================================================
:syscall_exit
.80090000 .00000100 .00008004 03300000  # ld s3, 72(sp)

# Decrement next_process_num
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00000002 03300000  # ld t1, 0x20(t0)
.00030000 .00000300 .0000F0FF 13000000  # addi t1, t1, -1
.00800200 .00006000 .00000002 23300000  # sd t1, 0x20(t0)

# If returning to shell (next_process_num == 1): no parent clone to restore
.80030000 .00001000 13000000  # li t2, 1
.00000300 .00007000 @exit_to_shell 63000000  # beq t1, t2, exit_to_shell

# Returning to parent after fork
# Parent saved state at proc[next_process_num - 1] (clone saves at get_process_base)
.80030000 .00000300 .0000F0FF 13000000  # addi t2, t1, -1
.80030000 .00800300 .0000C000 13100000  # slli t2, t2, 12
.000E0000 .00002040 37000000  # lui t3, 0x40200
.000E0000 .00000E00 .00001000 13100000  # slli t3, t3, 1
.000A0000 .00000E00 .00007000 33000000  # add s4, t3, t2

# Save child exit code
.00000A00 .00003001 .00080002 23300000  # sd s3, 0x30(s4)

# Restore parent process memory
.00050000 .00000A00 .00000000 03300000  # ld a0, 0(s4)
.80050000 .00000A00 .00008003 03300000  # ld a1, 0x38(s4)
.00060000 .00000A00 .00000004 03300000  # ld a2, 0x40(s4)
.80000000 $memcpy 6F000000  # call memcpy

# Deallocate save area: reset next_save_process_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00000A00 .00008004 03300000  # ld t1, 0x48(s4)
.00800200 .00006000 .00040002 23300000  # sd t1, 0x28(t0)

# Restore parent brk
.00030000 .00000A00 .00008002 03300000  # ld t1, 0x28(s4)
.00800200 .00006000 .00000004 23300000  # sd t1, 0x40(t0)

# Restore parent stack pointer
.00010000 .00000A00 .00008001 03300000  # ld sp, 0x18(s4)

# Restore parent stack contents
.80050000 .00000A00 .00008004 03300000  # ld a1, 0x48(s4)
.00050000 .00000100 13000000  # mv a0, sp
.00060000 .00000A00 .00000005 03300000  # ld a2, 0x50(s4)
.80000000 $memcpy 6F000000  # call memcpy

# Restore parent user stack
.00050000 .00000100 .00008000 03300000  # ld a0, 8(sp)
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00050000 .00000500 .00005000 33000000  # add a0, a0, t0
.80050000 .00000A00 .00008005 03300000  # ld a1, 0x58(s4)
.00060000 .00000A00 .00000006 03300000  # ld a2, 0x60(s4)
.80000000 $memcpy 6F000000  # call memcpy

# Flush I-cache after restoring parent code/data
0F100000  # fence.i

# Return 1 (parent return from fork)
.80020000 .00001000 13000000  # li t0, 1
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$trap_exit 6F000000  # j trap_exit

:exit_to_shell
# Restore kernel sp from proc[1]+0x10 (fixed location)
.80020000 .00002040 37000000  # lui t0, 0x40200
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00100000 37000000  # lui t1, 1
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00010000 .00800200 .00000001 03300000  # ld sp, 0x10(t0)

# Jump to shell_return (disables paging, goes to shell_loop)
$shell_return 6F000000  # j shell_return

#============================================================
# syscall_waitid: waitid(idtype, id, infop, options, ...)
# Returns child exit code in infop->si_status
# Simplified: just return 0, exit code already stored
#============================================================
:syscall_waitid
# Get current process descriptor
.80000000 $get_process_base 6F000000  # call get_process_base
.80020000 .00000500 .00000003 03300000  # ld t0, 0x30(a0)

# The infop struct: write status. For Linux compatibility,
# write exit code to [infop+0x18] (si_status field)
# But our programs (kaem) check [ecx] on x86, which maps to
# a1 (infop pointer) on riscv64.
.00030000 .00000100 .00000005 03300000  # ld t1, 80(sp)
# Actually RISC-V waitid: a0=idtype, a1=id, a2=infop, a3=options
.00030000 .00000100 .00008005 03300000  # ld t1, 88(sp)
.00000300 @waitid_no_write 63000000  # beqz t1, waitid_no_write

# Translate infop VA -> PA
.80030000 .00000040 37000000  # lui t2, 0x40000
.80030000 .00800300 .00001000 13100000  # slli t2, t2, 1
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2

# Write exit code shifted left by 8 (Linux convention)
.80020000 .00800200 .00008000 13100000  # slli t0, t0, 8
.00000300 .00005000 .00000000 23200000  # sw t0, 0(t1)

:waitid_no_write
.00000100 .00000000 .00040004 23300000  # sd zero, 72(sp)
$trap_exit 6F000000  # j trap_exit

#============================================================
# syscall_wait4: wait4(pid, wstatus, options, rusage)
# a0(72)=pid, a1(80)=wstatus_ptr, a2(88)=options, a3(96)=rusage
# In our simulation, child already exited. Just write wstatus.
#============================================================
:syscall_wait4
# Get current process descriptor
.80000000 $get_process_base 6F000000  # call get_process_base
.80020000 .00000500 .00000003 03300000  # ld t0, 0x30(a0)

# Get wstatus pointer (a1)
.00030000 .00000100 .00000005 03300000  # ld t1, 80(sp)
.00000300 @wait4_no_write 63000000  # beqz t1, wait4_no_write

# Translate VA -> PA
.80030000 .00000040 37000000  # lui t2, 0x40000
.80030000 .00800300 .00001000 13100000  # slli t2, t2, 1
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2

# Write wstatus = (exit_code << 8) (WIFEXITED=true, WEXITSTATUS=exit_code)
.80020000 .00800200 .00008000 13100000  # slli t0, t0, 8
.00000300 .00005000 .00000000 23200000  # sw t0, 0(t1)

:wait4_no_write
# Return child pid (1 = any child)
.80020000 .00001000 13000000  # li t0, 1
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$trap_exit 6F000000  # j trap_exit

