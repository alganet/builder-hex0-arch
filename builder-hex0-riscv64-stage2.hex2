.00030000 .00800500 .00000000 03400000  # lbu t1, 0(a1)
.00800200 .00006000 @strcmp_diff 63100000  # bne t0, t1, strcmp_diff
.00800200 @strcmp_equal 63000000  # beqz t0, strcmp_equal
.00050000 .00000500 .00001000 13000000  # addi a0, a0, 1
.80050000 .00800500 .00001000 13000000  # addi a1, a1, 1
$strcmp 6F000000  # j strcmp
:strcmp_equal
.00050000 .00000000 13000000  # li a0, 0
67800000  # ret
:strcmp_diff
.00050000 .00800200 .00006000 33000040  # sub a0, t0, t1
67800000  # ret

