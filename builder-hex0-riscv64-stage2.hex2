.00000A00 .00005000 .000C0000 23200000  # sw t0, 24(s4)
.80020000 .00001000 13000000  # li t0, 1
.00000A00 .00005000 .000E0000 23100000  # sh t0, 28(s4)
.80020000 .00002000 13000000  # li t0, 2
.00000A00 .00005000 .000F0000 23100000  # sh t0, 30(s4)

# Descriptor 2: status (device writes)
.80020000 .00200000 37000000  # lui t0, 2
.80020000 .00000A00 .00005000 33000000  # add t0, s4, t0
.80020000 .00800200 .00000001 13000000  # addi t0, t0, 0x10
.00000A00 .00005000 .00000002 23300000  # sd t0, 32(s4)
.80020000 .00001000 13000000  # li t0, 1
.00000A00 .00005000 .00040002 23200000  # sw t0, 40(s4)
.80020000 .00002000 13000000  # li t0, 2
.00000A00 .00005000 .00060002 23100000  # sh t0, 44(s4)
.00000A00 .00000000 .00070002 23100000  # sh zero, 46(s4)

# Add to available ring
.00050000 .00000A00 .00000008 13000000  # addi a0, s4, 0x80
.00000500 .00000000 .00000000 23100000  # sh zero, 0(a0)
.80020000 .00000500 .00002000 03500000  # lhu t0, 2(a0)
.00030000 .00800200 .00007000 13700000  # andi t1, t0, 7
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00030000 .00000300 .00004000 13000000  # addi t1, t1, 4
.00030000 .00000500 .00006000 33000000  # add t1, a0, t1
.00000300 .00000000 .00000000 23100000  # sh zero, 0(t1)
.80020000 .00800200 .00001000 13000000  # addi t0, t0, 1
.00000500 .00005000 .00010000 23100000  # sh t0, 2(a0)

# Notify
0F00F00F  # fence
.00800900 .00000000 .00080004 23200000  # sw zero, 0x50(s3)

# Poll used ring
.80020000 .00100000 37000000  # lui t0, 1
.00050000 .00000A00 .00005000 33000000  # add a0, s4, t0
:virtio_write_poll
0F00F00F  # fence
.80020000 .00000500 .00002000 03500000  # lhu t0, 2(a0)
.00800200 .00008000 @virtio_write_poll 63000000  # beq t0, s0, virtio_write_poll

# ACK interrupt
.80020000 .00800900 .00000006 03200000  # lw t0, 0x60(s3)
.00800900 .00005000 .00020006 23200000  # sw t0, 0x64(s3)

# Check status
.80020000 .00200000 37000000  # lui t0, 2
.80020000 .00000A00 .00005000 33000000  # add t0, s4, t0
.80020000 .00800200 .00000001 13000000  # addi t0, t0, 0x10
.00050000 .00800200 .00000000 03400000  # lbu a0, 0(t0)

.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00040000 .00000100 .00008000 03300000  # ld s0, 8(sp)
.80040000 .00000100 .00000001 03300000  # ld s1, 16(sp)
.80090000 .00000100 .00008001 03300000  # ld s3, 24(sp)
.000A0000 .00000100 .00000002 03300000  # ld s4, 32(sp)
.00010000 .00000100 .00000003 13000000  # addi sp, sp, 48
67800000  # ret

#============================================================
# SPI+SD Driver (SiFive SPI controller + SD card over SPI)
#
# SiFive SPI registers (offsets from base):
#   SCKDIV  0x00  Clock divisor
#   SCKMODE 0x04  SPI mode (polarity/phase)
#   CSID    0x10  Chip select ID
#   CSDEF   0x14  CS default (active-low)
#   CSMODE  0x18  CS mode (0=auto, 2=hold, 3=off)
#   TXDATA  0x48  TX FIFO (bit 31 = full)
#   RXDATA  0x4C  RX FIFO (bit 31 = empty)
#   FCTRL   0x60  Flash interface control (must be 0 for raw SPI)
#============================================================

#============================================================
# spi_transfer: Exchange one byte over SPI
# a0 = byte to send
# Returns: a0 = byte received
# Expects SPI base in globals+0x098
#============================================================
:spi_transfer
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00800200 .00008009 03300000  # ld t0, 0x98(t0)

# Wait for TX not full (bit 31 = 0)
:spi_tx_wait
.00030000 .00800200 .00008004 03200000  # lw t1, 0x48(t0)
.00000300 @spi_tx_wait 63400000  # bltz t1, spi_tx_wait
# Write byte
.00800200 .0000A000 .00040004 23200000  # sw a0, 0x48(t0)

# Wait for RX not empty (bit 31 = 0)
:spi_rx_wait
.00050000 .00800200 .0000C004 03200000  # lw a0, 0x4C(t0)
.00000500 @spi_rx_wait 63400000  # bltz a0, spi_rx_wait
.00050000 .00000500 .0000F00F 13700000  # andi a0, a0, 0xFF
67800000  # ret

#============================================================
# spi_sd_cmd: Send an SD command and get R1 response
# a0 = command byte (0x40 | cmd_index)
# a1 = 32-bit argument
# a2 = CRC byte
# Returns: a0 = R1 response byte
#============================================================
:spi_sd_cmd
.00010000 .00000100 .000000FF 13000000  # addi sp, sp, -16
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)

# spi_transfer only clobbers a0/t0/t1, so a1 (arg) and a2 (CRC) survive

# Send command byte (a0 already has it)
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Send 4 argument bytes (big-endian, a1 preserved across calls)
.00050000 .00800500 .00008001 13500000  # srli a0, a1, 24
.00050000 .00000500 .0000F00F 13700000  # andi a0, a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .00800500 .00000001 13500000  # srli a0, a1, 16
.00050000 .00000500 .0000F00F 13700000  # andi a0, a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .00800500 .00008000 13500000  # srli a0, a1, 8
.00050000 .00000500 .0000F00F 13700000  # andi a0, a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .00800500 .0000F00F 13700000  # andi a0, a1, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Send CRC byte (a2 preserved across calls)
.00050000 .00000600 13000000  # mv a0, a2
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Poll for response (up to 8 bytes, wait for bit 7 = 0)
.00040000 .00008000 13000000  # li s0, 8
:spi_sd_cmd_poll
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.80020000 .00000500 .00000008 13700000  # andi t0, a0, 0x80
.00800200 @spi_sd_cmd_done 63000000  # beqz t0, spi_sd_cmd_done
.00040000 .00000400 .0000F0FF 13000000  # addi s0, s0, -1
.00000400 @spi_sd_cmd_poll 63100000  # bnez s0, spi_sd_cmd_poll
.00050000 .0000F00F 13000000  # li a0, 0xFF

:spi_sd_cmd_done
.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00040000 .00000100 .00008000 03300000  # ld s0, 8(sp)
.00010000 .00000100 .00000001 13000000  # addi sp, sp, 16
67800000  # ret

#============================================================
# spi_sd_init: Configure SPI+SD for stage 2 use
# a0 = SPI controller MMIO base (from fdt_find_storage)
# Stage 1 already initialized the SD card. This just stores
# the SPI base in globals and sets disk function pointers.
#============================================================
:spi_sd_init
# Leaf function — no calls, no stack needed

# Store SPI base in globals
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00800200 .0000A000 .000C0008 23300000  # sd a0, 0x98(t0)
.00800200 .0000A000 .00000000 23300000  # sd a0, 0(t0)

# Set disk function pointers
.00030000 ~spi_sd_read_sector 17000000  # la t1, spi_sd_read_sector (auipc)
.00030000 .00000300 !spi_sd_read_sector 13000000  # la t1, spi_sd_read_sector (addi)
.00800200 .00006000 .00040008 23300000  # sd t1, 0x88(t0)
.00030000 ~spi_sd_write_sector 17000000  # la t1, spi_sd_write_sector (auipc)
.00030000 .00000300 !spi_sd_write_sector 13000000  # la t1, spi_sd_write_sector (addi)
.00800200 .00006000 .00080008 23300000  # sd t1, 0x90(t0)

67800000  # ret

#============================================================
# spi_sd_read_sector: Read one 512-byte sector from SD card
# a0 = sector number, a1 = destination buffer address
# Returns: a0 = 0 on success
#============================================================
:spi_sd_read_sector
.00010000 .00000100 .000080FE 13000000  # addi sp, sp, -24
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00003001 .00080000 23300000  # sd s3, 16(sp)

.00040000 .00800500 13000000  # mv s0, a1
.80090000 .00000500 13000000  # mv s3, a0

# CMD17: READ_SINGLE_BLOCK (byte address = sector * 512)
.00050000 .00001005 13000000  # li a0, 0x51
.80050000 .00800900 .00009000 13100000  # slli a1, s3, 9
.00060000 .0000F00F 13000000  # li a2, 0xFF
.80000000 $spi_sd_cmd 6F000000  # call spi_sd_cmd

# Wait for data token (0xFE)
# First 0xFF consumes the bridge RESPONSE→DATA_START transition
:spi_sd_read_wait_token
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.80020000 .0000E00F 13000000  # li t0, 0xFE
.00000500 .00005000 @spi_sd_read_wait_token 63100000  # bne a0, t0, spi_sd_read_wait_token

# Read 512 bytes
.80090000 .00000020 13000000  # li s3, 512
:spi_sd_read_loop
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00000400 .0000A000 .00000000 23000000  # sb a0, 0(s0)
.00040000 .00000400 .00001000 13000000  # addi s0, s0, 1
.80090000 .00800900 .0000F0FF 13000000  # addi s3, s3, -1
.00800900 @spi_sd_read_loop 63100000  # bnez s3, spi_sd_read_loop

# Read 2 CRC bytes (discard)
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer

.00050000 .00000000 13000000  # li a0, 0

.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00040000 .00000100 .00008000 03300000  # ld s0, 8(sp)
.80090000 .00000100 .00000001 03300000  # ld s3, 16(sp)
.00010000 .00000100 .00008001 13000000  # addi sp, sp, 24
67800000  # ret

#============================================================
# spi_sd_write_sector: Write one 512-byte sector to SD card
# a0 = sector number, a1 = source buffer address
# Returns: a0 = 0 on success
#============================================================
:spi_sd_write_sector
.00010000 .00000100 .000080FE 13000000  # addi sp, sp, -24
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00003001 .00080000 23300000  # sd s3, 16(sp)

.00040000 .00800500 13000000  # mv s0, a1
.80090000 .00000500 13000000  # mv s3, a0

# CMD24: WRITE_SINGLE_BLOCK (byte address = sector * 512)
.00050000 .00008005 13000000  # li a0, 0x58
.80050000 .00800900 .00009000 13100000  # slli a1, s3, 9
.00060000 .0000F00F 13000000  # li a2, 0xFF
.80000000 $spi_sd_cmd 6F000000  # call spi_sd_cmd

# Send data token (0xFE)
# First 0xFF consumes the RESPONSE→CMD transition, then 0xFE starts write
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .0000E00F 13000000  # li a0, 0xFE
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Write 512 bytes
.80090000 .00000020 13000000  # li s3, 512
:spi_sd_write_loop
.00050000 .00000400 .00000000 03400000  # lbu a0, 0(s0)
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00040000 .00000400 .00001000 13000000  # addi s0, s0, 1
.80090000 .00800900 .0000F0FF 13000000  # addi s3, s3, -1
.00800900 @spi_sd_write_loop 63100000  # bnez s3, spi_sd_write_loop

# Send 2 dummy CRC bytes
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Wait for data response token
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer

# Wait while card is busy (DO = 0x00)
:spi_sd_write_busy
.00050000 .0000F00F 13000000  # li a0, 0xFF
.80000000 $spi_transfer 6F000000  # call spi_transfer
.00000500 @spi_sd_write_busy 63000000  # beqz a0, spi_sd_write_busy

.00050000 .00000000 13000000  # li a0, 0

.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00040000 .00000100 .00008000 03300000  # ld s0, 8(sp)
.80090000 .00000100 .00000001 03300000  # ld s3, 16(sp)
.00010000 .00000100 .00008001 13000000  # addi sp, sp, 24
67800000  # ret

#============================================================
# internalshell: Main command loop (runs in S-mode, paging OFF)
# Reads commands from stdin (disk) and dispatches them
#============================================================
:internalshell
.00010000 .00000100 .000000FC 13000000  # addi sp, sp, -64
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00009000 .00080000 23300000  # sd s1, 16(sp)
.00000100 .00002001 .000C0000 23300000  # sd s2, 24(sp)
.00000100 .00003001 .00000002 23300000  # sd s3, 32(sp)
.00000100 .00004001 .00040002 23300000  # sd s4, 40(sp)
.00000100 .00005001 .00080002 23300000  # sd s5, 48(sp)
.00000100 .00006001 .000C0002 23300000  # sd s6, 56(sp)

:shell_loop
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.00040000 .00000500 13000000  # mv s0, a0

# End of input (null byte)
.00000400 @shell_done 63000000  # beqz s0, shell_done

# Skip newlines and carriage returns
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000400 .00005000 @shell_loop 63000000  # beq s0, t0, shell_loop
.80020000 .0000D000 13000000  # li t0, 0x0D
.00000400 .00005000 @shell_loop 63000000  # beq s0, t0, shell_loop

# Skip comments (lines starting with '#')
.80020000 .00003002 13000000  # li t0, 0x23
.00000400 .00005000 @shell_skip_comment 63000000  # beq s0, t0, shell_skip_comment

# Check for 's' (src command)
.80020000 .00003007 13000000  # li t0, 0x73
.00000400 .00005000 @handle_src 63000000  # beq s0, t0, handle_src

# Check for 'h' (hex0 command)
.80020000 .00008006 13000000  # li t0, 0x68
.00000400 .00005000 @handle_hex0 63000000  # beq s0, t0, handle_hex0

# Check for 'f' (enable flush)
.80020000 .00006006 13000000  # li t0, 0x66
.00000400 .00005000 @handle_flush 63000000  # beq s0, t0, handle_flush

# Other character: external command
$handle_other_command 6F000000  # j handle_other_command

:shell_skip_comment
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000500 .00005000 @shell_skip_comment 63100000  # bne a0, t0, shell_skip_comment
$shell_loop 6F000000  # j shell_loop

:shell_done
# Print "Done.\n"
.00050000 .00004004 13000000  # li a0, 0x44
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000F006 13000000  # li a0, 0x6F
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000E006 13000000  # li a0, 0x6E
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00005006 13000000  # li a0, 0x65
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000E002 13000000  # li a0, 0x2E
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Flush disk
.80000000 $flush_disk 6F000000  # call flush_disk

# Shutdown
$reboot 6F000000  # j reboot

#============================================================
# handle_flush: 'f' command - enable disk flushing
#============================================================
:handle_flush
# Skip rest of line (newline)
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte

# Set enable_flush = 1
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00001000 13000000  # li t1, 1
.00800200 .00006000 .00040004 23300000  # sd t1, 0x48(t0)

# Print "f\n"
.00050000 .00006006 13000000  # li a0, 0x66
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

$shell_loop 6F000000  # j shell_loop

#============================================================
# handle_src: 's' command - read file from stdin
# Format: src N filename\n<N bytes>
# Already read 's', need to skip "rc "
# Register plan:
#   s1 = byte count (decrements to 0)
#   s2 = original byte count
#   s3 = file descriptor table entry address
#   s4 = write pointer (into file data area)
#============================================================
:handle_src
# Print "src "
.00050000 .00003007 13000000  # li a0, 0x73
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00002007 13000000  # li a0, 0x72
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00003006 13000000  # li a0, 0x63
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00000002 13000000  # li a0, 0x20
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Skip "rc "
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte

# Parse decimal count into s1
.80040000 .00000000 13000000  # li s1, 0
:src_parse_count
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .00000002 13000000  # li t0, 0x20
.00000500 .00005000 @src_count_done 63000000  # beq a0, t0, src_count_done
.80020000 .0000A000 13000000  # li t0, 10
.80040000 .00800400 .00005000 33000002  # mul s1, s1, t0
.00050000 .00000500 .000000FD 13000000  # addi a0, a0, -0x30
.80040000 .00800400 .0000A000 33000000  # add s1, s1, a0
$src_parse_count 6F000000  # j src_parse_count
:src_count_done
.00090000 .00800400 13000000  # mv s2, s1

# Read filename into scratch buffer at 0xA0000000
.80090000 .00000050 37000000  # lui s3, 0x50000
.80090000 .00800900 .00001000 13100000  # slli s3, s3, 1
.000A0000 .00800900 13000000  # mv s4, s3
:src_read_name
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000500 .00005000 @src_name_done 63000000  # beq a0, t0, src_name_done
.00000A00 .0000A000 .00000000 23000000  # sb a0, 0(s4)
.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
$src_read_name 6F000000  # j src_read_name
:src_name_done
.00000A00 .00000000 .00000000 23000000  # sb zero, 0(s4)

# Print filename + newline
.00050000 .00800900 13000000  # mv a0, s3
.80000000 $print_string 6F000000  # call print_string
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Resolve to absolute path
.00050000 .00800900 13000000  # mv a0, s3
.80000000 $absolute_path 6F000000  # call absolute_path
.80090000 .00000500 13000000  # mv s3, a0

# Allocate new file entry
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000A0000 .00800200 .00000001 03300000  # ld s4, 0x10(t0)

# Copy filename to file names table (0x80800000 + index * 1024)
.00030000 .00000150 37000000  # lui t1, 0x50010
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00000A00 .0000A000 13100000  # slli t2, s4, 10
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2
.80030000 .00800900 13000000  # mv t2, s3
:src_copy_fname
.000E0000 .00800300 .00000000 03400000  # lbu t3, 0(t2)
.00000300 .0000C001 .00000000 23000000  # sb t3, 0(t1)
.00000E00 @src_fname_done 63000000  # beqz t3, src_fname_done
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.80030000 .00800300 .00001000 13000000  # addi t2, t2, 1
$src_copy_fname 6F000000  # j src_copy_fname
:src_fname_done

# Set up global file descriptor (0x81000000 + index * 16)
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00000A00 .00004000 13100000  # slli t1, s4, 4
.80090000 .00800200 .00006000 33000000  # add s3, t0, t1
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008001 03300000  # ld t1, 0x18(t0)
.00800900 .00006000 .00000000 23300000  # sd t1, 0(s3)
.00800900 .00000000 .00040000 23300000  # sd zero, 8(s3)

# Increment next_filenum
.00030000 .00800200 .00000001 03300000  # ld t1, 0x10(t0)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.00800200 .00006000 .00080000 23300000  # sd t1, 0x10(t0)

# s4 = write pointer = file_address
.000A0000 .00800900 .00000000 03300000  # ld s4, 0(s3)

# Read s1 bytes from stdin and write to file
:src_read_data
.00800400 @src_data_done 63000000  # beqz s1, src_data_done
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.00000A00 .0000A000 .00000000 23000000  # sb a0, 0(s4)
.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
.80040000 .00800400 .0000F0FF 13000000  # addi s1, s1, -1
$src_read_data 6F000000  # j src_read_data
:src_data_done

# Set file length = original count (s2)
.00800900 .00002001 .00040000 23300000  # sd s2, 8(s3)

# Advance next_file_address by count
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008001 03300000  # ld t1, 0x18(t0)
.00030000 .00000300 .00002001 33000000  # add t1, t1, s2
.00800200 .00006000 .000C0000 23300000  # sd t1, 0x18(t0)

$shell_loop 6F000000  # j shell_loop

#============================================================
# handle_hex0: 'h' command - compile hex0 source to binary
# Format: hex0 input output\n
# Already read 'h', need to skip "ex0 "
# Register plan:
#   s1 = input filename (in scratch)
#   s2 = output filename (in scratch + 0x400)
#   s3 = input file address
#   s4 = input file length / read offset
#   s5 = output file desc entry
#   s6 = output write pointer
#   s0 = hex state (0=first nibble, 1=second nibble), high nibble
#============================================================
:handle_hex0
# Print "hex0 "
.00050000 .00008006 13000000  # li a0, 0x68
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00005006 13000000  # li a0, 0x65
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00008007 13000000  # li a0, 0x78
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00000003 13000000  # li a0, 0x30
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00000002 13000000  # li a0, 0x20
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Skip "ex0 "
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte

# Read input filename into scratch at 0xA0000000
.80040000 .00000050 37000000  # lui s1, 0x50000
.80040000 .00800400 .00001000 13100000  # slli s1, s1, 1
.000A0000 .00800400 13000000  # mv s4, s1
:hex0_read_input
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .00000002 13000000  # li t0, 0x20
.00000500 .00005000 @hex0_input_done 63000000  # beq a0, t0, hex0_input_done
.00000A00 .0000A000 .00000000 23000000  # sb a0, 0(s4)
.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
$hex0_read_input 6F000000  # j hex0_read_input
:hex0_input_done
.00000A00 .00000000 .00000000 23000000  # sb zero, 0(s4)

# Print input filename + space
.00050000 .00800400 13000000  # mv a0, s1
.80000000 $print_string 6F000000  # call print_string
.00050000 .00000002 13000000  # li a0, 0x20
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Read output filename into scratch + 0x400
.00090000 .00000050 37000000  # lui s2, 0x50000
.00090000 .00000900 .00001000 13100000  # slli s2, s2, 1
.00090000 .00000900 .00000040 13000000  # addi s2, s2, 0x400
.000A0000 .00000900 13000000  # mv s4, s2
:hex0_read_output
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000500 .00005000 @hex0_output_done 63000000  # beq a0, t0, hex0_output_done
.00000A00 .0000A000 .00000000 23000000  # sb a0, 0(s4)
.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
$hex0_read_output 6F000000  # j hex0_read_output
:hex0_output_done
.00000A00 .00000000 .00000000 23000000  # sb zero, 0(s4)

# Print output filename + newline
.00050000 .00000900 13000000  # mv a0, s2
.80000000 $print_string 6F000000  # call print_string
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Resolve input filename and find file
.00050000 .00800400 13000000  # mv a0, s1
.80000000 $absolute_path 6F000000  # call absolute_path
.80040000 .00000500 13000000  # mv s1, a0
.80000000 $find_file 6F000000  # call find_file
.00000500 @shell_loop 63400000  # bltz a0, shell_loop
.000A0000 .00000500 13000000  # mv s4, a0

# Get input file address and length
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00000A00 .00004000 13100000  # slli t1, s4, 4
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.80090000 .00800200 .00000000 03300000  # ld s3, 0(t0)
.000A0000 .00800200 .00008000 03300000  # ld s4, 8(t0)

# Resolve output filename and create file
.00050000 .00000900 13000000  # mv a0, s2
.80000000 $absolute_path 6F000000  # call absolute_path
.00090000 .00000500 13000000  # mv s2, a0

# Allocate output file
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.800A0000 .00800200 .00000001 03300000  # ld s5, 0x10(t0)

# Copy output filename to file names table
.00030000 .00000150 37000000  # lui t1, 0x50010
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00800A00 .0000A000 13100000  # slli t2, s5, 10
.00030000 .00000300 .00007000 33000000  # add t1, t1, t2
.80030000 .00000900 13000000  # mv t2, s2
:hex0_copy_outname
.000E0000 .00800300 .00000000 03400000  # lbu t3, 0(t2)
.00000300 .0000C001 .00000000 23000000  # sb t3, 0(t1)
.00000E00 @hex0_outname_done 63000000  # beqz t3, hex0_outname_done
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.80030000 .00800300 .00001000 13000000  # addi t2, t2, 1
$hex0_copy_outname 6F000000  # j hex0_copy_outname
:hex0_outname_done

# Set up output file descriptor
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800A00 .00004000 13100000  # slli t1, s5, 4
.800A0000 .00800200 .00006000 33000000  # add s5, t0, t1
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008001 03300000  # ld t1, 0x18(t0)
.00800A00 .00006000 .00000000 23300000  # sd t1, 0(s5)
.00800A00 .00000000 .00040000 23300000  # sd zero, 8(s5)

# Increment next_filenum
.00030000 .00800200 .00000001 03300000  # ld t1, 0x10(t0)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.00800200 .00006000 .00080000 23300000  # sd t1, 0x10(t0)

# s6 = output write pointer
.000B0000 .00800A00 .00000000 03300000  # ld s6, 0(s5)

# Compile hex0: read input file byte by byte
# s0 low byte = hex state flag (0=need first nibble, nonzero=have first)
# s0 byte 1 = high nibble value
.00040000 .00000000 13000000  # li s0, 0
.80040000 .00000000 13000000  # li s1, 0

:hex0_compile_loop
# Check if we've read all input bytes
.00800400 .00004001 @hex0_compile_done 63500000  # bge s1, s4, hex0_compile_done

# Read one byte from input file
.80020000 .00800900 .00009000 33000000  # add t0, s3, s1
.00050000 .00800200 .00000000 03400000  # lbu a0, 0(t0)
.80040000 .00800400 .00001000 13000000  # addi s1, s1, 1

# Skip comments (# and ;)
.80020000 .00003002 13000000  # li t0, 0x23
.00000500 .00005000 @hex0_skip_comment 63000000  # beq a0, t0, hex0_skip_comment
.80020000 .0000B003 13000000  # li t0, 0x3B
.00000500 .00005000 @hex0_skip_comment 63000000  # beq a0, t0, hex0_skip_comment

# Convert hex char to nibble
# '0'-'9' -> 0-9
.80020000 .00000003 13000000  # li t0, 0x30
.00000500 .00005000 @hex0_compile_loop 63400000  # blt a0, t0, hex0_compile_loop
.80020000 .0000A003 13000000  # li t0, 0x3A
.00000500 .00005000 @hex0_digit 63400000  # blt a0, t0, hex0_digit
# 'A'-'F' -> 10-15
.80020000 .00001004 13000000  # li t0, 0x41
.00000500 .00005000 @hex0_compile_loop 63400000  # blt a0, t0, hex0_compile_loop
.80020000 .00007004 13000000  # li t0, 0x47
.00000500 .00005000 @hex0_upper 63400000  # blt a0, t0, hex0_upper
# 'a'-'f' -> 10-15
.80020000 .00001006 13000000  # li t0, 0x61
.00000500 .00005000 @hex0_compile_loop 63400000  # blt a0, t0, hex0_compile_loop
.80020000 .00007006 13000000  # li t0, 0x67
.00000500 .00005000 @hex0_lower 63400000  # blt a0, t0, hex0_lower
$hex0_compile_loop 6F000000  # j hex0_compile_loop

:hex0_digit
.00050000 .00000500 .000000FD 13000000  # addi a0, a0, -0x30
$hex0_got_nibble 6F000000  # j hex0_got_nibble

:hex0_upper
.00050000 .00000500 .000090FC 13000000  # addi a0, a0, -0x37
$hex0_got_nibble 6F000000  # j hex0_got_nibble

:hex0_lower
.00050000 .00000500 .000090FA 13000000  # addi a0, a0, -0x57
$hex0_got_nibble 6F000000  # j hex0_got_nibble

:hex0_got_nibble
# Check state
.80020000 .00000400 .0000F00F 13700000  # andi t0, s0, 0xFF
.00800200 @hex0_second_nibble 63100000  # bnez t0, hex0_second_nibble

# First nibble: save it
.00050000 .00000500 .00004000 13100000  # slli a0, a0, 4
.00050000 .00000500 .00008000 13100000  # slli a0, a0, 8
.80020000 .00001000 13000000  # li t0, 1
.00040000 .00000500 .00005000 33600000  # or s0, a0, t0
$hex0_compile_loop 6F000000  # j hex0_compile_loop

:hex0_second_nibble
# Combine with saved high nibble
.80020000 .00000400 .00008000 13500000  # srli t0, s0, 8
.80020000 .00800200 .0000000F 13700000  # andi t0, t0, 0xF0
.80020000 .00800200 .0000A000 33600000  # or t0, t0, a0
.00000B00 .00005000 .00000000 23000000  # sb t0, 0(s6)
.000B0000 .00000B00 .00001000 13000000  # addi s6, s6, 1
.00040000 .00000000 13000000  # li s0, 0
$hex0_compile_loop 6F000000  # j hex0_compile_loop

:hex0_skip_comment
# Skip to end of line
.00800400 .00004001 @hex0_compile_done 63500000  # bge s1, s4, hex0_compile_done
.80020000 .00800900 .00009000 33000000  # add t0, s3, s1
.00050000 .00800200 .00000000 03400000  # lbu a0, 0(t0)
.80040000 .00800400 .00001000 13000000  # addi s1, s1, 1
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000500 .00005000 @hex0_skip_comment 63100000  # bne a0, t0, hex0_skip_comment
$hex0_compile_loop 6F000000  # j hex0_compile_loop

:hex0_compile_done
# Set output file length
.80020000 .00800A00 .00000000 03300000  # ld t0, 0(s5)
.80020000 .00000B00 .00005000 33000040  # sub t0, s6, t0
.00800A00 .00005000 .00040000 23300000  # sd t0, 8(s5)

# Advance next_file_address
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00000300 .00008001 03300000  # ld t2, 0x18(t1)
.80030000 .00800300 .00005000 33000000  # add t2, t2, t0
.00000300 .00007000 .000C0000 23300000  # sd t2, 0x18(t1)

$shell_loop 6F000000  # j shell_loop

#============================================================
# handle_other_command: Execute external program
# First char already in s0
# Format: command_name arg\n
# Register plan:
#   s1 = command name buffer (0xA0000000)
#   s2 = argument buffer (0xA0000400)
#   s3, s4 = temporaries
#============================================================
:handle_other_command
# Check if we need to flush disk
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008004 03300000  # ld t1, 0x48(t0)
.00000300 @hoc_no_flush 63000000  # beqz t1, hoc_no_flush
.80000000 $flush_disk 6F000000  # call flush_disk
:hoc_no_flush

# Command name buffer at scratch + 0x800
.80040000 .00000050 37000000  # lui s1, 0x50000
.80040000 .00800400 .00001000 13100000  # slli s1, s1, 1
.80020000 .00000000 .00001000 13000000  # addi t0, zero, 1
.80020000 .00800200 .0000B000 13100000  # slli t0, t0, 11
.80040000 .00800400 .00005000 33000000  # add s1, s1, t0
# Store first char (already in s0)
.00800400 .00008000 .00000000 23000000  # sb s0, 0(s1)
.00090000 .00800400 .00001000 13000000  # addi s2, s1, 1

# Read rest of command name until space
:hoc_read_name
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .00000002 13000000  # li t0, 0x20
.00000500 .00005000 @hoc_name_done 63000000  # beq a0, t0, hoc_name_done
.00000900 .0000A000 .00000000 23000000  # sb a0, 0(s2)
.00090000 .00000900 .00001000 13000000  # addi s2, s2, 1
$hoc_read_name 6F000000  # j hoc_read_name
:hoc_name_done
.00000900 .00000000 .00000000 23000000  # sb zero, 0(s2)

# Argument buffer at scratch + 0xC00
.00090000 .00000050 37000000  # lui s2, 0x50000
.00090000 .00000900 .00001000 13100000  # slli s2, s2, 1
.80020000 .00000000 .00003000 13000000  # addi t0, zero, 3
.80020000 .00800200 .0000A000 13100000  # slli t0, t0, 10
.00090000 .00000900 .00005000 33000000  # add s2, s2, t0
.80090000 .00000900 13000000  # mv s3, s2
:hoc_read_arg
.80000000 $read_stdin_byte 6F000000  # call read_stdin_byte
.80020000 .0000A000 13000000  # li t0, 0x0A
.00000500 .00005000 @hoc_arg_done 63000000  # beq a0, t0, hoc_arg_done
.00800900 .0000A000 .00000000 23000000  # sb a0, 0(s3)
.80090000 .00800900 .00001000 13000000  # addi s3, s3, 1
$hoc_read_arg 6F000000  # j hoc_read_arg
:hoc_arg_done
.00800900 .00000000 .00000000 23000000  # sb zero, 0(s3)

# Print command name + space + arg + newline
.00050000 .00800400 13000000  # mv a0, s1
.80000000 $print_string 6F000000  # call print_string
.00050000 .00000002 13000000  # li a0, 0x20
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .00000900 13000000  # mv a0, s2
.80000000 $print_string 6F000000  # call print_string
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar

# Set up argv in global data: cmd_args at globals+0x58
# argv[0] = command name, argv[1] = arg, argv[2] = NULL
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00800200 .00009000 .000C0004 23300000  # sd s1, 0x58(t0)
.00800200 .00002001 .00000006 23300000  # sd s2, 0x60(t0)
.00800200 .00000000 .00040006 23300000  # sd zero, 0x68(t0)
.00800200 .00000000 .00080006 23300000  # sd zero, 0x70(t0)

# Resolve command name to absolute path
.00050000 .00800400 13000000  # mv a0, s1
.80000000 $absolute_path 6F000000  # call absolute_path
.80040000 .00000500 13000000  # mv s1, a0

# Find executable file
.80000000 $find_file 6F000000  # call find_file
.00000500 @hoc_not_found 63400000  # bltz a0, hoc_not_found
.80090000 .00000500 13000000  # mv s3, a0

# Get file address and length
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800900 .00004000 13100000  # slli t1, s3, 4
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.80090000 .00800200 .00000000 03300000  # ld s3, 0(t0)
.000A0000 .00800200 .00008000 03300000  # ld s4, 8(t0)

# Increment next_process_num
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00000002 03300000  # ld t1, 0x20(t0)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.00800200 .00006000 .00000002 23300000  # sd t1, 0x20(t0)

# Get process descriptor for new process
.80000000 $get_process_base 6F000000  # call get_process_base
.800A0000 .00000500 13000000  # mv s5, a0

# Copy cwd from previous process
.80020000 .00100000 37000000  # lui t0, 1
.80020000 .00800A00 .00005000 33000040  # sub t0, s5, t0
.00030000 .00800200 .00000010 13000000  # addi t1, t0, 0x100
.80030000 .00800A00 .00000010 13000000  # addi t2, s5, 0x100
.000E0000 .00000010 13000000  # li t3, 256
:hoc_copy_cwd
.00000E00 @hoc_cwd_done 63000000  # beqz t3, hoc_cwd_done
.800E0000 .00000300 .00000000 03400000  # lbu t4, 0(t1)
.00800300 .0000D001 .00000000 23000000  # sb t4, 0(t2)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.80030000 .00800300 .00001000 13000000  # addi t2, t2, 1
.000E0000 .00000E00 .0000F0FF 13000000  # addi t3, t3, -1
$hoc_copy_cwd 6F000000  # j hoc_copy_cwd
:hoc_cwd_done

# Clear open file descriptors
.00050000 .00800A00 .00000020 13000000  # addi a0, s5, 0x200
.80050000 .00100000 37000000  # li a1, 3584 (upper)
.80050000 .00800500 .000000E0 13000000  # li a1, 3584 (lower)
.80000000 $memset_zero 6F000000  # call memset_zero

# Parse 64-bit ELF header
.000B0000 .00800900 .00008001 03300000  # ld s6, 0x18(s3)
.80020000 .00800900 .00000002 03300000  # ld t0, 0x20(s3)
.000A0000 .00800900 .00005000 33000000  # add s4, s3, t0
.00040000 .00800900 .00008003 03500000  # lhu s0, 0x38(s3)

# Zero 2MB of user process area at PA 0x80600000
.00050000 .00003040 37000000  # lui a0, 0x40300
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80050000 .00002000 37000000  # lui a1, 0x200
.80000000 $memset_zero 6F000000  # call memset_zero

# Reset brk
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00003840 37000000  # lui t1, 0x40380
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00800200 .00006000 .00000004 23300000  # sd t1, 0x40(t0)

# Load program headers
:hoc_load_phdr
.00000400 @hoc_load_done 63000000  # beqz s0, hoc_load_done
.80020000 .00000A00 .00000000 03200000  # lw t0, 0(s4)
.00030000 .00001000 13000000  # li t1, 1
.00800200 .00006000 @hoc_next_phdr 63100000  # bne t0, t1, hoc_next_phdr

.80020000 .00000A00 .00008000 03300000  # ld t0, 0x08(s4)
.80050000 .00800900 .00005000 33000000  # add a1, s3, t0
.80020000 .00000A00 .00000001 03300000  # ld t0, 0x10(s4)
.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00050000 .00800200 .00006000 33000000  # add a0, t0, t1
.00060000 .00000A00 .00000002 03300000  # ld a2, 0x20(s4)
.80000000 $memcpy 6F000000  # call memcpy

# Update brk = max(brk, end_of_segment_PA + padding)
.80020000 .00000A00 .00000001 03300000  # ld t0, 0x10(s4)
.00030000 .00000A00 .00000002 03300000  # ld t1, 0x20(s4)
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00030000 .00000040 37000000  # lui t1, 0x40000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00030000 .00200000 37000000  # lui t1, 2
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00000300 .00000004 03300000  # ld t2, 0x40(t1)
.00800300 .00005000 @hoc_next_phdr 63500000  # bge t2, t0, hoc_next_phdr
.00000300 .00005000 .00000004 23300000  # sd t0, 0x40(t1)

:hoc_next_phdr
.000A0000 .00000A00 .00008003 13000000  # addi s4, s4, 56
.00040000 .00000400 .0000F0FF 13000000  # addi s0, s0, -1
$hoc_load_phdr 6F000000  # j hoc_load_phdr

:hoc_load_done
# Set process_address
.80020000 .00003040 37000000  # lui t0, 0x40300
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00800A00 .00005000 .00000000 23300000  # sd t0, 0(s5)

# Clear forked flag
.00800A00 .00000000 .00000002 23300000  # sd zero, 0x20(s5)

# Save current sp at proc[1]+0x10 (fixed location for shell return)
.80020000 .00002040 37000000  # lui t0, 0x40200
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00100000 37000000  # lui t1, 1
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00800200 .00002000 .00080000 23300000  # sd sp, 0x10(t0)

# Set up user stack at PA 0x90000000 (VA 0x10000000)
.80020000 .00000048 37000000  # lui t0, 0x48000
.00040000 .00800200 .00001000 13100000  # slli s0, t0, 1

# Push NULL (envp terminator)
.00040000 .00000400 .000080FF 13000000  # addi s0, s0, -8
.00000400 .00000000 .00000000 23300000  # sd zero, 0(s0)

# Push NULL (argv terminator)
.00040000 .00000400 .000080FF 13000000  # addi s0, s0, -8
.00000400 .00000000 .00000000 23300000  # sd zero, 0(s0)

# Push argv[1] VA = arg string
# arg is at PA s2 = 0xA0000C00. But user needs VA.
# Copy arg to user-accessible area at PA 0x8FF00000 (VA 0x0FF00000)
.80020000 .0000F847 37000000  # lui t0, 0x47F80
.80090000 .00800200 .00001000 13100000  # slli s3, t0, 1
.00050000 .00800900 13000000  # mv a0, s3
.80050000 .00000900 13000000  # mv a1, s2
.00060000 .00000010 13000000  # li a2, 256
.80000000 $memcpy 6F000000  # call memcpy
# VA of arg = 0x0FF00000
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00800900 .00005000 33000040  # sub t0, s3, t0
.00040000 .00000400 .000080FF 13000000  # addi s0, s0, -8
.00000400 .00005000 .00000000 23300000  # sd t0, 0(s0)

# Push argv[0] VA = command name
# Copy command name to PA 0x8FF00100 (VA 0x0FF00100)
.000A0000 .00800900 .00000010 13000000  # addi s4, s3, 0x100
.00050000 .00000A00 13000000  # mv a0, s4
.80050000 .00800400 13000000  # mv a1, s1
.00060000 .00000010 13000000  # li a2, 256
.80000000 $memcpy 6F000000  # call memcpy
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00000A00 .00005000 33000040  # sub t0, s4, t0
.00040000 .00000400 .000080FF 13000000  # addi s0, s0, -8
.00000400 .00005000 .00000000 23300000  # sd t0, 0(s0)

# Push argc = 2
.00040000 .00000400 .000080FF 13000000  # addi s0, s0, -8
.80020000 .00002000 13000000  # li t0, 2
.00000400 .00005000 .00000000 23300000  # sd t0, 0(s0)

# User stack VA = PA - 0x80000000
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00040000 .00000400 .00005000 33000040  # sub s0, s0, t0

# --- Transition to U-mode ---
0F00F00F  # fence
0F100000  # fence.i

# Clear SPP (bit 8), SPIE (bit 5), SIE (bit 1) in sstatus
.80020000 .00002012 13000000  # li t0, 0x122
.00000000 .00800200 .00000010 73300000  # csrrc zero, sstatus, t0

# Set sepc = entry point VA (s6)
.00000000 .00000B00 .00001014 73100000  # csrrw zero, sepc, s6

# Set sscratch = sp (kernel stack, for trap handler)
.00000000 .00000100 .00000014 73100000  # csrrw zero, sscratch, sp

# Enable paging
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00800200 .00008007 03300000  # ld t0, 0x78(t0)
.00000000 .00800200 .00000018 73100000  # csrrw zero, satp, t0
73000012  # sfence.vma

# Set sp = user stack VA and sret
.00010000 .00000400 13000000  # mv sp, s0
73002010  # sret

# --- We never reach here directly ---
# When the user program calls exit, syscall_exit runs.
# exit_to_shell restores sp from proc descriptor and does ret.
# That ret returns here (to the instruction after the call that
# led us here... but we used 'j', not 'call').
# Actually, exit_to_shell loads sp from proc+0x10 and does ret.
# Since we saved sp BEFORE sret, ret will pop ra from that sp.
# But ra on the kernel stack at that point is... from the call
# chain that led to handle_other_command.
# handle_other_command was jumped to from shell_loop (j instruction).
# So ra is still whatever internalshell set. This won't work.
# We need to save a return address.

# Let me fix this: instead of saving sp, save sp and put a
# known return address. After exit_to_shell does ret,
# we need to end up back at shell_loop.

# The fix: exit_to_shell will jump to shell_return instead of ret.

:hoc_not_found
# Print "?\n"
.00050000 .0000F003 13000000  # li a0, 0x3F
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.00050000 .0000A000 13000000  # li a0, 0x0A
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
$shell_loop 6F000000  # j shell_loop

# Return point after user program exits
:shell_return
# Disable paging (we're back in S-mode)
.00000000 .00000000 .00000018 73100000  # csrrw zero, satp, zero
73000012  # sfence.vma
$shell_loop 6F000000  # j shell_loop

#============================================================
# flush_disk: Write /dev/hda file contents back to disk
#============================================================
:flush_disk
.00010000 .00000100 .000000FE 13000000  # addi sp, sp, -32
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00009000 .00080000 23300000  # sd s1, 16(sp)
.00000100 .00002001 .000C0000 23300000  # sd s2, 24(sp)

# Find /dev/hda
.00050000 .00000050 37000000  # lui a0, 0x50000
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80020000 .0000F002 13000000  # li t0, 0x2F
.00000500 .00005000 .00000000 23000000  # sb t0, 0(a0)
.80020000 .00004006 13000000  # li t0, 0x64
.00000500 .00005000 .80000000 23000000  # sb t0, 1(a0)
.80020000 .00005006 13000000  # li t0, 0x65
.00000500 .00005000 .00010000 23000000  # sb t0, 2(a0)
.80020000 .00006007 13000000  # li t0, 0x76
.00000500 .00005000 .80010000 23000000  # sb t0, 3(a0)
.80020000 .0000F002 13000000  # li t0, 0x2F
.00000500 .00005000 .00020000 23000000  # sb t0, 4(a0)
.80020000 .00008006 13000000  # li t0, 0x68
.00000500 .00005000 .80020000 23000000  # sb t0, 5(a0)
.80020000 .00004006 13000000  # li t0, 0x64
.00000500 .00005000 .00030000 23000000  # sb t0, 6(a0)
.80020000 .00001006 13000000  # li t0, 0x61
.00000500 .00005000 .80030000 23000000  # sb t0, 7(a0)
.00000500 .00000000 .00040000 23000000  # sb zero, 8(a0)
.80000000 $find_file 6F000000  # call find_file
.00000500 @flush_done 63400000  # bltz a0, flush_done

# Get file address and length
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00000500 .00004000 13100000  # slli t1, a0, 4
.80020000 .00800200 .00006000 33000000  # add t0, t0, t1
.00040000 .00800200 .00000000 03300000  # ld s0, 0(t0)
.80040000 .00800200 .00008000 03300000  # ld s1, 8(t0)

# Write sector by sector
.00090000 .00000000 13000000  # li s2, 0
:flush_sector_loop
.00009000 @flush_done 63500000  # blez s1, flush_done

# Write 512 bytes from s0 to disk sector s2
.00050000 .00000900 13000000  # mv a0, s2
.80050000 .00000400 13000000  # mv a1, s0
.80000000 $disk_write_sector 6F000000  # call disk_write_sector

.00040000 .00000400 .00000020 13000000  # addi s0, s0, 512
.80040000 .00800400 .000000E0 13000000  # addi s1, s1, -512
.00090000 .00000900 .00001000 13000000  # addi s2, s2, 1
$flush_sector_loop 6F000000  # j flush_sector_loop

:flush_done
.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.00040000 .00000100 .00008000 03300000  # ld s0, 8(sp)
.80040000 .00000100 .00000001 03300000  # ld s1, 16(sp)
.00090000 .00000100 .00008001 03300000  # ld s2, 24(sp)
.00010000 .00000100 .00000002 13000000  # addi sp, sp, 32
67800000  # ret

#============================================================
# main: Boot sequence
#============================================================
:main
# Set sp = 0xA8000000 (kernel stack top)
.80020000 .00000054 37000000  # lui t0, 0x54000
.00010000 .00800200 .00001000 13100000  # slli sp, t0, 1

# Save a0 = stdin_sector and a1 = DTB pointer from stage1
.000B0000 .00000500 13000000  # mv s6, a0
.800B0000 .00800500 13000000  # mv s7, a1

# Load RAM base into s2 = 0x80210000
.80000000 $load_ram_base 6F000000  # call load_ram_base

# Set up trap handler early (before any MMIO access)
.80020000 .00000900 .00004000 13000000  # addi t0, s2, 4
.00000000 .00800200 .00005010 73100000  # csrrw zero, stvec, t0
# Set sscratch = kernel stack top (needed for trap handler)
.00000000 .00000100 .00000014 73100000  # csrrw zero, sscratch, sp
# Disable all S-mode interrupts (timer, external, software)
.00000000 .00000000 .00004010 73100000  # csrrw zero, sie, zero

# Parse device tree to find storage device
.00050000 .00800B00 13000000  # mv a0, s7
.80000000 $fdt_find_storage 6F000000  # call fdt_find_storage

# Dispatch to appropriate storage driver
.80020000 .00001000 13000000  # li t0, 1
.00800500 .00005000 @init_virtio 63000000  # beq a1, t0, init_virtio
.80020000 .00002000 13000000  # li t0, 2
.00800500 .00005000 @init_spi_sd 63000000  # beq a1, t0, init_spi_sd
$reboot 6F000000  # j reboot

:init_virtio
.80000000 $virtio_init 6F000000  # call virtio_init
$storage_ready 6F000000  # j storage_ready

:init_spi_sd
.80000000 $spi_sd_init 6F000000  # call spi_sd_init

:storage_ready

# --- Initialize filesystem ---

# Initialize global data
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1

# next_filenum = 3 (files 0-2 reserved)
.00030000 .00003000 13000000  # li t1, 3
.00800200 .00006000 .00080000 23300000  # sd t1, 0x10(t0)

# next_file_address = 0xD4000000
.00030000 .0000006A 37000000  # lui t1, 0x6A000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00800200 .00006000 .000C0000 23300000  # sd t1, 0x18(t0)

# next_process_num = 1
.00030000 .00001000 13000000  # li t1, 1
.00800200 .00006000 .00000002 23300000  # sd t1, 0x20(t0)

# next_save_process_address = 0xB0000000
.00030000 .00000058 37000000  # lui t1, 0x58000
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00800200 .00006000 .00040002 23300000  # sd t1, 0x28(t0)

# enable_flush = 0
.00800200 .00000000 .00040004 23300000  # sd zero, 0x48(t0)

# have_userspace = 0
.00800200 .00000000 .00080004 23300000  # sd zero, 0x50(t0)

# Store DTB pointer in globals for future use
.00800200 .00007001 .00000008 23300000  # sd s7, 0x80(t0)

# Initialize brk = 0x80700000 (PA, 1MB above ELF base)
.00030000 .00003840 37000000  # lui t1, 0x40380
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.00800200 .00006000 .00000004 23300000  # sd t1, 0x40(t0)

# Initialize stdin_sector from stage1 (a0 saved in s6), offset = 512 (force first read)
.00800200 .00006001 .00080002 23300000  # sd s6, 0x30(t0)
.00030000 .00000020 13000000  # li t1, 512
.00800200 .00006000 .000C0002 23300000  # sd t1, 0x38(t0)

# Zero process descriptors (16 * 4096 = 64KB at 0x80400000)
.00050000 .00002040 37000000  # lui a0, 0x40200
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80050000 .00000100 37000000  # lui a1, 0x10
.80000000 $memset_zero 6F000000  # call memset_zero

# Zero file names area (8MB at 0x80800000)
.00050000 .00000150 37000000  # lui a0, 0x50010
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80050000 .00008000 37000000  # lui a1, 0x800
.80000000 $memset_zero 6F000000  # call memset_zero

# Zero file descriptors area (512KB at 0x81000000)
.00050000 .00004150 37000000  # lui a0, 0x50410
.00050000 .00000500 .00001000 13100000  # slli a0, a0, 1
.80050000 .00000800 37000000  # lui a1, 0x80
.80000000 $memset_zero 6F000000  # call memset_zero

# Set process 0 current_dir = "/"
.80020000 .00002040 37000000  # lui t0, 0x40200
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .0000F002 13000000  # li t1, 0x2F
.00800200 .00006000 .00000010 23000000  # sb t1, 0x100(t0)
.00800200 .00000000 .80000010 23000000  # sb zero, 0x101(t0)
# Also set process 1 current_dir = "/"
.80030000 .00100000 37000000  # lui t2, 1
.80020000 .00800200 .00007000 33000000  # add t0, t0, t2
.00800200 .00006000 .00000010 23000000  # sb t1, 0x100(t0)
.00800200 .00000000 .80000010 23000000  # sb zero, 0x101(t0)

# Set up trap handler
# stvec = s2 + 4 (trap_handler is at offset 4 from _start)
.80020000 .00000900 .00004000 13000000  # addi t0, s2, 4
.00000000 .00800200 .00005010 73100000  # csrrw zero, stvec, t0

# Set up Sv39 page table
.80000000 $setup_page_table 6F000000  # call setup_page_table

# Jump to internal shell
$internalshell 6F000000  # j internalshell
