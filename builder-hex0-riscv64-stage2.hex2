.80000000 $bswap32 6F000000  # call bswap32
.800A0000 .00000500 .00000002 13100000  # slli s5, a0, 32
.00050000 .00800400 .00004000 03200000  # lw a0, 4(s1)
.80000000 $bswap32 6F000000  # call bswap32
.800A0000 .00800A00 .0000A000 33600000  # or s5, s5, a0

# If this is a spi@ node, save the base immediately (before child nodes reset s5)
