# SPDX-FileCopyrightText: 2026 Alexandre Gomes Gaigalas <alganet@gmail.com>
# SPDX-License-Identifier: Apache-2.0
#
# Builder-hex0 RISC-V 64-bit Stage 2
#
# A minimal kernel for bootstrapping compilers from source on RISC-V.
# Inspired by builder-hex0 (https://github.com/ironmeld/builder-hex0).
#
# Boot (virt):     qemu-system-riscv64 -machine virt -m 2G -nographic \
#                  -kernel builder-hex0-riscv64-stage1-virt.bin \
#                  -drive file=disk.img,format=raw,if=none,id=hd0 \
#                  -device virtio-blk-device,drive=hd0 --no-reboot
# Boot (sifive_u): qemu-system-riscv64 -machine sifive_u -m 2G -nographic \
#                  -kernel builder-hex0-riscv64-stage1-sifive_u.bin \
#                  -drive file=disk.img,format=raw,if=sd --no-reboot
#
# Compiled by stage 1 from hex0 source on disk to 0x80210000.
# On entry: a0 = next disk sector (filesystem start), a1 = DTB pointer
#
# Memory layout (physical addresses):
#   0x80100000  Sv39 root page table (4KB)
#   0x80210000  Kernel code (base, s2 points here)
#   0x80300000  Kernel global data (variables)
#   0x80400000  Process descriptors (16 x 4096)
#   0x80500000  VirtIO structures (desc/avail/used/buffers)
#   0x80600000  User process area (VA 0x00600000 via Sv39 gigapage)
#   0x90000000  User stack top (VA 0x10000000, grows down)
#   0xA0000000  Scratch buffer (64KB)
#   0xA0010000  stdin device buffer (64KB)
#   0xA0020000  File names (8MB, 8192 entries x 1024 bytes)
#   0xA0820000  File descriptors (512KB, 32768 x 16 bytes)
#   0xA8000000  Kernel stack top (grows down) / sscratch
#   0xB0000000  Saved process memory (bump allocator)
#   0xD4000000  File data (bump allocator, next_file_address)
#
# Sv39 paging (gigapages, root table only):
#   Entry 0: VA 0x00000000-0x3FFFFFFF -> PA 0x80000000 (U|R|W|X|V)
#   Entry 2: VA 0x80000000-0xBFFFFFFF -> PA 0x80000000 (R|W|X|V)
#   Entry 3: VA 0xC0000000-0xFFFFFFFF -> PA 0xC0000000 (R|W|X|V)
#   Kernel disables paging (satp=0) on trap entry, enables before sret
#
# Global data at 0x80300000:
#   +0x000: storage_mmio_base (8 bytes) [VirtIO MMIO or SPI controller base]
#   +0x008: virtio_struct_base (8 bytes) [VirtIO only]
#   +0x010: next_filenum (8 bytes)
#   +0x018: next_file_address (8 bytes)
#   +0x020: next_process_num (8 bytes)
#   +0x028: next_save_process_address (8 bytes)
#   +0x030: stdin_sector (8 bytes)
#   +0x038: stdin_offset (8 bytes)
#   +0x040: current_brk (8 bytes)  [PA, per-process simplified]
#   +0x048: enable_flush (8 bytes)
#   +0x050: have_userspace (8 bytes)
#   +0x058: cmd_args (3x8: argv[0], argv[1], NULL)
#   +0x070: cmd_env (1x8: NULL)
#   +0x078: satp_value (8 bytes)
#   +0x080: dtb_pointer (8 bytes)
#   +0x088: disk_read_fn (8 bytes)   [function pointer, set by storage driver]
#   +0x090: disk_write_fn (8 bytes)  [function pointer, set by storage driver]
#   +0x098: spi_base (8 bytes)       [SPI+SD only, used by spi_transfer]
#
# Process descriptor (4096 bytes each, at 0x80400000):
#   +0x000: process_address (8)
#   +0x008: brk (8)
#   +0x010: saved_stack_pointer (8) [return-to-shell]
#   +0x018: saved_stack_pointer_fork (8)
#   +0x020: forked (8)
#   +0x028: saved_brk (8)
#   +0x030: child_exit_code (8)
#   +0x038: saved_process_mem_addr (8)
#   +0x040: saved_process_mem_len (8)
#   +0x048: saved_stack_addr (8)
#   +0x050: saved_stack_len (8)
#   +0x100: current_dir (256 bytes, null-terminated, trailing /)
#   +0x200: open_files (448 entries x 8 bytes)
#            each: global_file_index(4), current_offset(4)
#
# Global file descriptor table (16 bytes each, at 0x81000000):
#   +0x00: file_address (8)
#   +0x08: file_length (8)
#
# File names table (1024 bytes each, at 0x80800000):
#   Null-terminated absolute paths
#
# VirtIO structures at 0x80500000:
#   +0x0000: Descriptor table (8 entries x 16 bytes = 128)
#   +0x0080: Available ring (flags + idx + 8 entries = 22 bytes)
#   +0x1000: Used ring (flags + idx + 8 entries = 68 bytes)
#   +0x2000: Request header (16 bytes)
#   +0x2010: Status byte
#   +0x3000: Sector buffer (512 bytes)
#
# Register conventions:
#   s2 = RAM base (0x80210000), set during boot
#   s3 = VirtIO MMIO base, available during boot
#   s4 = VirtIO struct base (0x80500000), available during boot
#   s5 = global data base (0x80300000), available during boot
#   sp = kernel stack pointer (in sscratch during U-mode)
#
# Trap handler at offset 4 from binary start

:_start
.00000000 $main 6F000000  # jal zero, main

#============================================================
# Trap handler (at offset 4 = address 0x80210004)
# Entered on ecall from U-mode (scause = 8)
#============================================================
:trap_handler
# Swap sp and sscratch: sp = kernel sp, sscratch = user sp
.00010000 .00000100 .00000014 73100000  # csrrw sp, sscratch, sp
# Disable paging (kernel operates on physical addresses)
.00000000 .00000000 .00000018 73100000  # csrrw zero, satp, zero
73000012  # sfence.vma
# Quick sanity: if sp < 0x80000000, sscratch was wrong
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00000100 .00005000 @trap_sp_ok 63700000  # bgeu sp, t0, trap_sp_ok
# Bad sp! sp = old sscratch (bad kernel sp?), sscratch = old user sp
# Save bad sp value before overwriting
.00030000 .00000100 13000000  # mv t1, sp
# Set sp to a safe kernel stack area: 0xA7F00000
.80020000 .0000F853 37000000  # lui t0, 0x53F80
.00010000 .00800200 .00001000 13100000  # slli sp, t0, 1
.00010000 .00000100 .000000FC 13000000  # addi sp, sp, -64
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00008000 .00040000 23300000  # sd s0, 8(sp)
.00000100 .00009000 .00080000 23300000  # sd s1, 16(sp)
.00040000 .00000300 13000000  # mv s0, t1
.80040000 .00000000 .00000014 73200000  # csrrs s1, sscratch, zero
$reboot 6F000000  # j reboot
:trap_sp_ok
# Allocate trap frame (256 bytes = 32 slots of 8 bytes)
.00010000 .00000100 .000000F0 13000000  # addi sp, sp, -256
# Save t0 first (we use it as scratch for CSR reads)
.00000100 .00005000 .00000002 23300000  # sd t0, 32(sp)
# Save user sp (from sscratch) into frame
.80020000 .00000000 .00000014 73200000  # csrrs t0, sscratch, zero
.00000100 .00005000 .00040000 23300000  # sd t0, 8(sp)
# Save sepc into frame
.80020000 .00000000 .00001014 73200000  # csrrs t0, sepc, zero
.00000100 .00005000 .000C000E 23300000  # sd t0, 248(sp)
# Save remaining registers
.00000100 .00001000 .00000000 23300000  # sd ra, 0(sp)
.00000100 .00003000 .00080000 23300000  # sd gp, 16(sp)
.00000100 .00004000 .000C0000 23300000  # sd tp, 24(sp)
# t0 already saved at 32
.00000100 .00006000 .00040002 23300000  # sd t1, 40(sp)
.00000100 .00007000 .00080002 23300000  # sd t2, 48(sp)
.00000100 .00008000 .000C0002 23300000  # sd s0, 56(sp)
.00000100 .00009000 .00000004 23300000  # sd s1, 64(sp)
.00000100 .0000A000 .00040004 23300000  # sd a0, 72(sp)
.00000100 .0000B000 .00080004 23300000  # sd a1, 80(sp)
.00000100 .0000C000 .000C0004 23300000  # sd a2, 88(sp)
.00000100 .0000D000 .00000006 23300000  # sd a3, 96(sp)
.00000100 .0000E000 .00040006 23300000  # sd a4, 104(sp)
.00000100 .0000F000 .00080006 23300000  # sd a5, 112(sp)
.00000100 .00000001 .000C0006 23300000  # sd a6, 120(sp)
.00000100 .00001001 .00000008 23300000  # sd a7, 128(sp)
.00000100 .00002001 .00040008 23300000  # sd s2, 136(sp)
.00000100 .00003001 .00080008 23300000  # sd s3, 144(sp)
.00000100 .00004001 .000C0008 23300000  # sd s4, 152(sp)
.00000100 .00005001 .0000000A 23300000  # sd s5, 160(sp)
.00000100 .00006001 .0004000A 23300000  # sd s6, 168(sp)
.00000100 .00007001 .0008000A 23300000  # sd s7, 176(sp)
.00000100 .00008001 .000C000A 23300000  # sd s8, 184(sp)
.00000100 .00009001 .0000000C 23300000  # sd s9, 192(sp)
.00000100 .0000A001 .0004000C 23300000  # sd s10, 200(sp)
.00000100 .0000B001 .0008000C 23300000  # sd s11, 208(sp)
.00000100 .0000C001 .000C000C 23300000  # sd t3, 216(sp)
.00000100 .0000D001 .0000000E 23300000  # sd t4, 224(sp)
.00000100 .0000E001 .0004000E 23300000  # sd t5, 232(sp)
.00000100 .0000F001 .0008000E 23300000  # sd t6, 240(sp)

# Check scause == 8 (ecall from U-mode)
.80020000 .00000000 .00002014 73200000  # csrrs t0, scause, zero
.00030000 .00008000 13000000  # li t1, 8
.00800200 .00006000 @dispatch 63000000  # beq t0, t1, dispatch

# Not ecall from U-mode: terminate process with exit code 139
.80020000 .0000B008 13000000  # li t0, 139
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$syscall_exit 6F000000  # j syscall_exit

# Dispatch syscall based on a7
:dispatch
.80080000 .00000100 .00000008 03300000  # ld a7, 128(sp)

# All dispatch uses trampolines (J-type, ±1MB range)
.00030000 .00000004 13000000  # li t1, 64
.00800800 .00006000 @tramp_write 63000000  # beq a7, t1, tramp_write
.00030000 .0000D005 13000000  # li t1, 93
.00800800 .00006000 @tramp_exit 63000000  # beq a7, t1, tramp_exit
.00030000 .0000600D 13000000  # li t1, 214
.00800800 .00006000 @tramp_brk 63000000  # beq a7, t1, tramp_brk
.00030000 .0000F003 13000000  # li t1, 63
.00800800 .00006000 @tramp_read 63000000  # beq a7, t1, tramp_read
.00030000 .00008003 13000000  # li t1, 56
.00800800 .00006000 @tramp_openat 63000000  # beq a7, t1, tramp_openat
.00030000 .00009003 13000000  # li t1, 57
.00800800 .00006000 @tramp_close 63000000  # beq a7, t1, tramp_close
.00030000 .0000E003 13000000  # li t1, 62
.00800800 .00006000 @tramp_lseek 63000000  # beq a7, t1, tramp_lseek
.00030000 .00001003 13000000  # li t1, 49
.00800800 .00006000 @tramp_chdir 63000000  # beq a7, t1, tramp_chdir
.00030000 .00001001 13000000  # li t1, 17
.00800800 .00006000 @tramp_getcwd 63000000  # beq a7, t1, tramp_getcwd
.00030000 .00000003 13000000  # li t1, 48
.00800800 .00006000 @tramp_faccessat 63000000  # beq a7, t1, tramp_faccessat
.00030000 .00002002 13000000  # li t1, 34
.00800800 .00006000 @tramp_mkdirat 63000000  # beq a7, t1, tramp_mkdirat
.00030000 .0000C00D 13000000  # li t1, 220
.00800800 .00006000 @tramp_clone 63000000  # beq a7, t1, tramp_clone
.00030000 .0000D00D 13000000  # li t1, 221
.00800800 .00006000 @tramp_execve 63000000  # beq a7, t1, tramp_execve
.00030000 .0000F005 13000000  # li t1, 95
.00800800 .00006000 @tramp_waitid 63000000  # beq a7, t1, tramp_waitid
.00030000 .00004010 13000000  # li t1, 260
.00800800 .00006000 @tramp_wait4 63000000  # beq a7, t1, tramp_wait4
.00030000 .00000006 13000000  # li t1, 96
.00800800 .00006000 @tramp_stub 63000000  # beq a7, t1, tramp_stub
.00030000 .0000D001 13000000  # li t1, 29
.00800800 .00006000 @tramp_stub 63000000  # beq a7, t1, tramp_stub
.00030000 .00005003 13000000  # li t1, 53
.00800800 .00006000 @tramp_stub 63000000  # beq a7, t1, tramp_stub

# Unknown syscall
.80020000 .0000F0FF 13000000  # li t0, -1
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$trap_exit 6F000000  # j trap_exit

# Trampolines (J-type, ±1MB range)
:tramp_write
$syscall_write 6F000000  # j syscall_write
:tramp_exit
$syscall_exit 6F000000  # j syscall_exit
:tramp_brk
$syscall_brk 6F000000  # j syscall_brk
:tramp_read
$syscall_read 6F000000  # j syscall_read
:tramp_openat
$syscall_openat 6F000000  # j syscall_openat
:tramp_close
$syscall_close 6F000000  # j syscall_close
:tramp_lseek
$syscall_lseek 6F000000  # j syscall_lseek
:tramp_chdir
$syscall_chdir 6F000000  # j syscall_chdir
:tramp_getcwd
$syscall_getcwd 6F000000  # j syscall_getcwd
:tramp_faccessat
$syscall_faccessat 6F000000  # j syscall_faccessat
:tramp_mkdirat
$syscall_mkdirat 6F000000  # j syscall_mkdirat
:tramp_clone
$syscall_clone 6F000000  # j syscall_clone
:tramp_execve
$syscall_execve 6F000000  # j syscall_execve
:tramp_waitid
$syscall_waitid 6F000000  # j syscall_waitid
:tramp_wait4
$syscall_wait4 6F000000  # j syscall_wait4
:tramp_stub
$syscall_stub_zero 6F000000  # j syscall_stub_zero

#============================================================
# trap_exit: Restore all registers and sret
#============================================================
:trap_exit
# Restore sepc (incremented by 4 to skip ecall)
.80020000 .00000100 .0000800F 03300000  # ld t0, 248(sp)
.80020000 .00800200 .00004000 13000000  # addi t0, t0, 4
.00000000 .00800200 .00001014 73100000  # csrrw zero, sepc, t0
# Restore user sp to sscratch
.80020000 .00000100 .00008000 03300000  # ld t0, 8(sp)
.00000000 .00800200 .00000014 73100000  # csrrw zero, sscratch, t0
# Enable paging before returning to user mode
# (kernel code+stack are identity-mapped via gigapage 2, so this is safe)
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.80020000 .00800200 .00008007 03300000  # ld t0, 0x78(t0)
.00000000 .00800200 .00000018 73100000  # csrrw zero, satp, t0
73000012  # sfence.vma
# Restore all registers
.80000000 .00000100 .00000000 03300000  # ld ra, 0(sp)
.80010000 .00000100 .00000001 03300000  # ld gp, 16(sp)
.00020000 .00000100 .00008001 03300000  # ld tp, 24(sp)
.80020000 .00000100 .00000002 03300000  # ld t0, 32(sp)
.00030000 .00000100 .00008002 03300000  # ld t1, 40(sp)
.80030000 .00000100 .00000003 03300000  # ld t2, 48(sp)
.00040000 .00000100 .00008003 03300000  # ld s0, 56(sp)
.80040000 .00000100 .00000004 03300000  # ld s1, 64(sp)
.00050000 .00000100 .00008004 03300000  # ld a0, 72(sp)
.80050000 .00000100 .00000005 03300000  # ld a1, 80(sp)
.00060000 .00000100 .00008005 03300000  # ld a2, 88(sp)
.80060000 .00000100 .00000006 03300000  # ld a3, 96(sp)
.00070000 .00000100 .00008006 03300000  # ld a4, 104(sp)
.80070000 .00000100 .00000007 03300000  # ld a5, 112(sp)
.00080000 .00000100 .00008007 03300000  # ld a6, 120(sp)
.80080000 .00000100 .00000008 03300000  # ld a7, 128(sp)
.00090000 .00000100 .00008008 03300000  # ld s2, 136(sp)
.80090000 .00000100 .00000009 03300000  # ld s3, 144(sp)
.000A0000 .00000100 .00008009 03300000  # ld s4, 152(sp)
.800A0000 .00000100 .0000000A 03300000  # ld s5, 160(sp)
.000B0000 .00000100 .0000800A 03300000  # ld s6, 168(sp)
.800B0000 .00000100 .0000000B 03300000  # ld s7, 176(sp)
.000C0000 .00000100 .0000800B 03300000  # ld s8, 184(sp)
.800C0000 .00000100 .0000000C 03300000  # ld s9, 192(sp)
.000D0000 .00000100 .0000800C 03300000  # ld s10, 200(sp)
.800D0000 .00000100 .0000000D 03300000  # ld s11, 208(sp)
.000E0000 .00000100 .0000800D 03300000  # ld t3, 216(sp)
.800E0000 .00000100 .0000000E 03300000  # ld t4, 224(sp)
.000F0000 .00000100 .0000800E 03300000  # ld t5, 232(sp)
.800F0000 .00000100 .0000000F 03300000  # ld t6, 240(sp)
# Deallocate frame
.00010000 .00000100 .00000010 13000000  # addi sp, sp, 256
# Swap back: sp = user sp, sscratch = kernel sp
.00010000 .00000100 .00000014 73100000  # csrrw sp, sscratch, sp
# Return to user mode
73002010  # sret

#============================================================
# syscall_write: write(fd, buf, count) -> count
# a0(72)=fd, a1(80)=buf, a2(88)=count
#============================================================
:syscall_write
# Load args from trap frame
.80090000 .00000100 .00008004 03300000  # ld s3, 72(sp)
.000A0000 .00000100 .00000005 03300000  # ld s4, 80(sp)
.800A0000 .00000100 .00008005 03300000  # ld s5, 88(sp)
.000B0000 .00800A00 13000000  # mv s6, s5

# Translate buf VA -> PA
.80020000 .00000040 37000000  # lui t0, 0x40000
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.000A0000 .00000A00 .00005000 33000000  # add s4, s4, t0

# If fd <= 2, write to console
.80020000 .00003000 13000000  # li t0, 3
.00800900 .00005000 @write_console 63400000  # blt s3, t0, write_console
$write_file 6F000000  # j write_file

:write_console
:write_loop
.00800A00 @write_done 63000000  # beqz s5, write_done
.00050000 .00000A00 .00000000 03400000  # lbu a0, 0(s4)
.80000000 $sbi_putchar 6F000000  # call sbi_putchar
.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
.800A0000 .00800A00 .0000F0FF 13000000  # addi s5, s5, -1
$write_loop 6F000000  # j write_loop

:write_done
.00000100 .00006001 .00040004 23300000  # sd s6, 72(sp)
$trap_exit 6F000000  # j trap_exit

:write_file
# s3=fd, s4=buf, s5=count, s6=original count
# Get file info from process fd table
.00050000 .00800900 13000000  # mv a0, s3
.80000000 $fd_to_file_index 6F000000  # call fd_to_file_index
.800B0000 .00000500 13000000  # mv s7, a0

# Get file_address and file_length from global descriptor
.80020000 .00004150 37000000  # lui t0, 0x50410
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800B00 .00004000 13100000  # slli t1, s7, 4
.000C0000 .00800200 .00006000 33000000  # add s8, t0, t1
.800C0000 .00000C00 .00000000 03300000  # ld s9, 0(s8)
.000D0000 .00000C00 .00008000 03300000  # ld s10, 8(s8)

# Get current_offset from process fd
.80000000 $get_process_base 6F000000  # call get_process_base
.00050000 .00000500 .00000020 13000000  # addi a0, a0, 0x200
.80020000 .00800900 .00003000 13100000  # slli t0, s3, 3
.800D0000 .00000500 .00005000 33000000  # add s11, a0, t0
.80090000 .00800D00 .00004000 03600000  # lwu s3, 4(s11)

:write_file_loop
.00800A00 @write_file_done 63000000  # beqz s5, write_file_done

# Copy byte from user buf to file
.80020000 .00000A00 .00000000 03400000  # lbu t0, 0(s4)
.00030000 .00800C00 .00003001 33000000  # add t1, s9, s3
.00000300 .00005000 .00000000 23000000  # sb t0, 0(t1)


.000A0000 .00000A00 .00001000 13000000  # addi s4, s4, 1
.80090000 .00800900 .00001000 13000000  # addi s3, s3, 1
.800A0000 .00800A00 .0000F0FF 13000000  # addi s5, s5, -1

# If offset > file_length, extend file
.00000D00 .00003001 @write_file_loop 63500000  # bge s10, s3, write_file_loop

# Extend: file_length = offset
.000D0000 .00800900 13000000  # mv s10, s3
.00000C00 .0000A001 .00040000 23300000  # sd s10, 8(s8)

# Also advance next_file_address
.80020000 .00001840 37000000  # lui t0, 0x40180
.80020000 .00800200 .00001000 13100000  # slli t0, t0, 1
.00030000 .00800200 .00008001 03300000  # ld t1, 0x18(t0)
.00030000 .00000300 .00001000 13000000  # addi t1, t1, 1
.00800200 .00006000 .000C0000 23300000  # sd t1, 0x18(t0)

$write_file_loop 6F000000  # j write_file_loop

:write_file_done
# Update current_offset in process fd
.00800D00 .00003001 .00020000 23200000  # sw s3, 4(s11)
# Return original count
.00000100 .00006001 .00040004 23300000  # sd s6, 72(sp)
$trap_exit 6F000000  # j trap_exit

#============================================================
# syscall_brk: brk(addr) -> addr
# a0(72)=addr. If addr==0, return current brk.
# brk stored in global data at offset 0x40
#============================================================
:syscall_brk
.80020000 .00000100 .00008004 03300000  # ld t0, 72(sp)

# Global data at 0x80300000
.00030000 .00001840 37000000  # lui t1, 0x40180
.00030000 .00000300 .00001000 13100000  # slli t1, t1, 1
.80030000 .00000300 .00000004 03300000  # ld t2, 0x40(t1)

.00800200 @brk_return_current 63000000  # beqz t0, brk_return_current

# Convert VA to PA: PA = VA + 0x80000000
.000E0000 .00000040 37000000  # lui t3, 0x40000
.000E0000 .00000E00 .00001000 13100000  # slli t3, t3, 1
.80020000 .00800200 .0000C001 33000000  # add t0, t0, t3

# Zero memory from old brk to new brk if extending
.00800300 .00005000 @brk_store 63500000  # bge t2, t0, brk_store
.800E0000 .00800300 13000000  # mv t4, t2
:brk_zero_loop
.00800E00 .00005000 @brk_store 63500000  # bge t4, t0, brk_store
.00800E00 .00000000 .00000000 23000000  # sb zero, 0(t4)
.800E0000 .00800E00 .00001000 13000000  # addi t4, t4, 1
$brk_zero_loop 6F000000  # j brk_zero_loop

:brk_store
.00000300 .00005000 .00000004 23300000  # sd t0, 0x40(t1)
# Return VA to user
.80020000 .00800200 .0000C001 33000040  # sub t0, t0, t3
.00000100 .00005000 .00040004 23300000  # sd t0, 72(sp)
$trap_exit 6F000000  # j trap_exit

:brk_return_current
# Return current brk as VA = PA - 0x80000000
.000E0000 .00000040 37000000  # lui t3, 0x40000
.000E0000 .00000E00 .00001000 13100000  # slli t3, t3, 1
.80030000 .00800300 .0000C001 33000040  # sub t2, t2, t3
