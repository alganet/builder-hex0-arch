.00050000 .00800900 13000000  # mv a0, s3
.80000000 $find_file 6F000000  # call find_file
.00800B00 .00006001 .00000000 23000000  # sb s6, 0(s7)
.00000500 @mkdirat_fail 63400000  # bltz a0, mkdirat_fail

