; QEMU processes SDHCI commands instantly — no polling needed.
; Wait for Command Complete (bit 0) then clear status.
#:emmc_wait
ca 32 40 b9  # ldr w10, [x22, #0x30]
4b 01 40 92  # and w11, w10, #1
cb ff ff b4  # cbz w11, emmc_wait
ea ff 9f d2  # movz w10, #0xFFFF
ca 32 00 b9  # str w10, [x22, #0x30]
c0 03 5f d6  # ret

#:park_core
5f 20 03 d5  # wfe
ff ff ff 17  # b park_core
