c3 ff ff 97  # bl spi_transfer
1f f8 03 f1  # cmp x0, #0xFE
a1 ff ff 54  # b.ne spi_sd_read_wait_token

15 40 80 d2  # mov x21, #512
#:spi_sd_read_loop
