1f 00 00 f1  # cmp w0, #0
cb ff ff 54  # b.lt spi_rx_wait
00 1c 40 92  # and x0, x0, #0xFF
c0 03 5f d6  # ret

#:spi_sd_cmd
ff 43 00 d1  # sub sp, sp, #16
fe 03 00 f9  # str x30, [sp]
f3 07 00 f9  # str x19, [sp, #8]

f2 ff ff 97  # bl spi_transfer

20 fc 58 d3  # lsr x0, x1, #24
00 1c 40 92  # and x0, x0, #0xFF
ef ff ff 97  # bl spi_transfer
20 fc 50 d3  # lsr x0, x1, #16
00 1c 40 92  # and x0, x0, #0xFF
ec ff ff 97  # bl spi_transfer
20 fc 48 d3  # lsr x0, x1, #8
00 1c 40 92  # and x0, x0, #0xFF
e9 ff ff 97  # bl spi_transfer
20 1c 40 92  # and x0, x1, #0xFF
e7 ff ff 97  # bl spi_transfer

e0 03 02 aa  # mov x0, x2
e5 ff ff 97  # bl spi_transfer

13 01 80 d2  # mov x19, #8
#:spi_sd_cmd_poll
e0 1f 80 d2  # mov x0, #0xFF
e2 ff ff 97  # bl spi_transfer
09 00 79 92  # and x9, x0, #0x80
89 00 00 b4  # cbz x9, spi_sd_cmd_done
73 06 00 d1  # sub x19, x19, #1
73 ff ff b5  # cbnz x19, spi_sd_cmd_poll
e0 1f 80 d2  # mov x0, #0xFF

#:spi_sd_cmd_done
fe 03 40 f9  # ldr x30, [sp]
f3 07 40 f9  # ldr x19, [sp, #8]
ff 43 00 91  # add sp, sp, #16
c0 03 5f d6  # ret

#:spi_sd_init
09 06 a8 d2  # movz x9, #0x4030, lsl #16
    ; Convert SPI MMIO PA to VA by adding 0xC0000000 (Entry 3 mapping)
0a 00 b8 d2  # movz x10, #0xC000, lsl #16
00 00 0a 8b  # add x0, x0, x10
20 4d 00 f9  # str x0, [x9, #0x98]
20 01 00 f9  # str x0, [x9, #0]

aa 00 00 10  # adr x10, spi_sd_read_sector
2a 45 00 f9  # str x10, [x9, #0x88]
4a 04 00 10  # adr x10, spi_sd_write_sector
2a 49 00 f9  # str x10, [x9, #0x90]
c0 03 5f d6  # ret

#:spi_sd_read_sector
