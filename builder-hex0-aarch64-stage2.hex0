09 1c 00 39  # strb w9, [x0, #7]
1f 20 00 39  # strb wzr, [x0, #8]
56 fb ff 97  # bl find_file
1f 00 00 f1  # cmp x0, #0
ab 02 00 54  # b.lt flush_done

49 10 ac d2  # movz x9, #0x6082, lsl #16
0a ec 7c d3  # lsl x10, x0, #4
29 01 0a 8b  # add x9, x9, x10
33 01 40 f9  # ldr x19, [x9]
34 05 40 f9  # ldr x20, [x9, #8]

    ; Re-init SDHCI before writing (needed after CMD18 preload)
09 06 a8 d2  # movz x9, #0x4030, lsl #16
2a 55 40 f9  # ldr x10, [x9, #0xA8] # board_has_sdhci?
6a 00 00 b4  # cbz x10, flush_skip_reinit
36 01 40 f9  # ldr x22, [x9, #0x00] # SDHCI base
73 ff ff 97  # bl sdhci_reinit_card
#:flush_skip_reinit

15 00 80 d2  # mov x21, #0
#:flush_sector_loop
9f 02 00 f1  # cmp x20, #0
0d 01 00 54  # b.le flush_done

e0 03 15 aa  # mov x0, x21
e1 03 13 aa  # mov x1, x19
51 fc ff 97  # bl disk_write_sector

73 02 08 91  # add x19, x19, #512
94 02 08 d1  # sub x20, x20, #512
b5 06 00 91  # add x21, x21, #1
f8 ff ff 17  # b flush_sector_loop

#:flush_done
fe 03 40 f9  # ldr x30, [sp]
f3 07 40 f9  # ldr x19, [sp, #8]
f4 0b 40 f9  # ldr x20, [sp, #16]
f5 0f 40 f9  # ldr x21, [sp, #24]
ff 83 00 91  # add sp, sp, #32
c0 03 5f d6  # ret

;============================================================
; main: Boot sequence
;============================================================
#:main
    ; Use SP_EL1 for kernel, then set it
bf 41 00 d5  # msr spsel, #1
df 3f 03 d5  # isb
09 70 af d2  # movz x9, #0x7B80, lsl #16
3f 01 00 91  # mov sp, x9 # SP_EL1 = 0x7B800000

    ; Save x0 = stdin_sector and x1 = DTB pointer
f8 03 00 aa  # mov x24, x0
f9 03 01 aa  # mov x25, x1
fa 03 02 aa  # mov x26, x2
    ; x27 is set by _trampoline (3=raspi3b, 0=virt) — do not use x3


    ; Load RAM base into x20
f2 f9 ff 97  # bl load_ram_base

    ; Set up exception vector table
c9 7e fe 10  # adr x9, exception_vectors
09 c0 18 d5  # msr vbar_el1, x9

    ; Disable all EL1 interrupts
df 4f 03 d5  # msr daifset, #0xF

    ; Set UART base for non-raspi3b boards (virt: PA 0x09000000, Entry 3 VA 0xC9000000)
7f 0f 00 f1  # cmp x27, #3
60 01 00 54  # b.eq init_sdhci
09 20 b9 d2  # movz x9, #0xC900, lsl #16 # virt UART VA via Entry 3
0a 06 a8 d2  # movz x10, #0x4030, lsl #16
49 51 00 f9  # str x9, [x10, #0xA0]

    ; Parse device tree
e0 03 19 aa  # mov x0, x25
51 fb ff 97  # bl fdt_find_storage
3f 04 00 f1  # cmp x1, #1
a0 03 00 54  # b.eq init_virtio
3f 08 00 f1  # cmp x1, #2
e0 03 00 54  # b.eq init_spi_sd
e7 f9 ff 17  # b reboot
#:init_sdhci
    ; SDHCI and UART accessed via Entry 1 L2 Device entries (VA = PA + 0x40000000)
    ; x26 = SDHCI PA from stage1 (0x3F300000)
09 00 a8 d2  # movz x9, #0x4000, lsl #16
56 03 09 8b  # add x22, x26, x9 # x22 = SDHCI VA via Entry 1 (0x7F300000)
49 1f 68 92  # and x9, x26, #0xFF000000
0a 04 a0 d2  # movz x10, #0x0020, lsl #16
0a 00 82 f2  # movk x10, #0x1000
29 01 0a aa  # orr x9, x9, x10
0a 00 a8 d2  # movz x10, #0x4000, lsl #16
29 01 0a 8b  # add x9, x9, x10 # x9 = UART VA via Entry 1 (0x7F201000)
0a 06 a8 d2  # movz x10, #0x4030, lsl #16
49 51 00 f9  # str x9, [x10, #0xA0] # UART VA = 0x7F201000
56 01 00 f9  # str x22, [x10, #0x00] # SDHCI VA = 0x7F300000

    ; Initialize PL011 UART properly
    ; 1. Disable UART
3f 31 00 b9  # str wzr, [x9, #0x30]
    ; 2. Set UARTLCR_H: 8-bit word length (WLEN=11) + FIFO enable (FEN=1) = 0x70
0a 0e 80 d2  # movz w10, #0x70
2a 2d 00 b9  # str w10, [x9, #0x2C]
    ; 3. Enable UART (UARTEN=1, TXE=1, RXE=1 = 0x301)
2a 60 80 d2  # movz w10, #0x0301
2a 31 00 b9  # str w10, [x9, #0x30]

    ; No SDHCI re-init needed — stage1 already initialized the controller.
    ; The Entry 3 VA (0xFF300000) maps to the same PA (0x3F300000) that stage1 used.
    ; On raspi3b, MMU is already on — adr gives VA directly (no offset needed)
09 e3 ff 10  # adr x9, sdhci_read_sector
0a 06 a8 d2  # movz x10, #0x4030, lsl #16
49 45 00 f9  # str x9, [x10, #0x88]
29 ef ff 10  # adr x9, sdhci_write_sector
0a 06 a8 d2  # movz x10, #0x4030, lsl #16
49 49 00 f9  # str x9, [x10, #0x90]
29 00 80 d2  # mov x9, #1
49 55 00 f9  # str x9, [x10, #0xA8] # board_has_sdhci = 1
08 00 00 14  # b storage_ready
#:init_virtio
bf fb ff 97  # bl virtio_init
    ; Clear board_has_sdhci (only for non-SDHCI boards)
09 06 a8 d2  # movz x9, #0x4030, lsl #16
3f 55 00 f9  # str xzr, [x9, #0xA8]
04 00 00 14  # b storage_ready
#:init_spi_sd
dc fc ff 97  # bl spi_sd_init
    ; Clear board_has_sdhci (SPI+SD is not SDHCI)
09 06 a8 d2  # movz x9, #0x4030, lsl #16
3f 55 00 f9  # str xzr, [x9, #0xA8]
#:storage_ready

    ; Initialize global data
09 06 a8 d2  # movz x9, #0x4030, lsl #16

6a 00 80 d2  # mov x10, #3
2a 09 00 f9  # str x10, [x9, #0x10]

0a 32 b4 d2  # movz x10, #0xA190, lsl #16 # file data start past file names end
2a 0d 00 f9  # str x10, [x9, #0x18]

2a 00 80 d2  # mov x10, #1
2a 11 00 f9  # str x10, [x9, #0x20]

0a 00 af d2  # movz x10, #0x7800, lsl #16 # save area at VA 0x78000000 (PA 0x38000000)
2a 15 00 f9  # str x10, [x9, #0x28]

    ; board_has_sdhci is set by init_sdhci or cleared by init_virtio — not touched here
3f 25 00 f9  # str xzr, [x9, #0x48]
3f 29 00 f9  # str xzr, [x9, #0x50]
3f 3d 00 f9  # str xzr, [x9, #0x78] # stdin_buf_ptr = 0 (no preload; raspi3b sets this later)
0a 40 80 d2  # mov x10, #512
2a 1d 00 f9  # str x10, [x9, #0x38] # stdin_offset = 512 (trigger first sector read)

39 41 00 f9  # str x25, [x9, #0x80]

0a 0e a8 d2  # movz x10, #0x4070, lsl #16
2a 21 00 f9  # str x10, [x9, #0x40]

38 19 00 f9  # str x24, [x9, #0x30]
0a 40 80 d2  # mov x10, #512
2a 1d 00 f9  # str x10, [x9, #0x38]

    ; Zero process descriptors (64KB at 0x60400000)
00 08 ac d2  # movz x0, #0x6040, lsl #16
01 02 80 d2  # movz x1, #0x10, lsl #12
c2 f9 ff 97  # bl memset_zero

    ; Zero file names area (16MB at 0x60900000)
00 12 ac d2  # movz x0, #0x6090, lsl #16
01 20 a0 d2  # movz x1, #0x100, lsl #16
bf f9 ff 97  # bl memset_zero

    ; Zero file descriptors area (512KB at 0x60820000)
40 10 ac d2  # movz x0, #0x6082, lsl #16
01 01 a0 d2  # movz x1, #0x8, lsl #16
bc f9 ff 97  # bl memset_zero

    ; Set process 0 current_dir = "/"
09 08 ac d2  # movz x9, #0x6040, lsl #16
ea 05 80 d2  # mov w10, #0x2F
2a 01 04 39  # strb w10, [x9, #0x100]
3f 05 04 39  # strb wzr, [x9, #0x101]
    ; Process 1
0a 00 82 d2  # movz x10, #0x1000
29 01 0a 8b  # add x9, x9, x10
ea 05 80 d2  # mov w10, #0x2F
2a 01 04 39  # strb w10, [x9, #0x100]
3f 05 04 39  # strb wzr, [x9, #0x101]

    ; Set up page table (skip on raspi3b — trampoline already did it)
7f 0f 00 f1  # cmp x27, #3
00 01 00 54  # b.eq skip_page_table
f2 f9 ff 97  # bl setup_page_table
    ; Enable MMU (stays on forever) — preserve RES1 bits
09 10 38 d5  # mrs x9, sctlr_el1
29 01 40 b2  # orr x9, x9, #1
29 01 7e b2  # orr x9, x9, #4
29 01 74 b2  # orr x9, x9, #0x1000
09 10 18 d5  # msr sctlr_el1, x9
df 3f 03 d5  # isb
#:skip_page_table

    ; SDHCI re-init skipped — stage1's re-init left card in transfer state

#:sdhci_reinit_done

    ; Jump to internal shell
f6 fc ff 17  # b internalshell
