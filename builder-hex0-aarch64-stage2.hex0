be ff ff 97  # bl spi_transfer
60 02 00 39  # strb w0, [x19]
73 06 00 91  # add x19, x19, #1
b5 06 00 d1  # sub x21, x21, #1
75 ff ff b5  # cbnz x21, spi_sd_read_loop

e0 1f 80 d2  # mov x0, #0xFF
b8 ff ff 97  # bl spi_transfer
e0 1f 80 d2  # mov x0, #0xFF
b6 ff ff 97  # bl spi_transfer

00 00 80 d2  # mov x0, #0

fe 03 40 f9  # ldr x30, [sp]
f3 07 40 f9  # ldr x19, [sp, #8]
f5 0b 40 f9  # ldr x21, [sp, #16]
ff 83 00 91  # add sp, sp, #32
