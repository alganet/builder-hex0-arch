fe 03 00 f9  # str x30, [sp]
f3 07 00 f9  # str x19, [sp, #8]
f5 0b 00 f9  # str x21, [sp, #16]

f3 03 01 aa  # mov x19, x1
f5 03 00 aa  # mov x21, x0

20 0a 80 d2  # mov x0, #0x51
a1 da 77 d3  # lsl x1, x21, #9
e2 1f 80 d2  # mov x2, #0xFF
d0 ff ff 97  # bl spi_sd_cmd

