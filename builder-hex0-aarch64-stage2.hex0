;============================================================
; internalshell: Main command loop (runs in EL1, MMU ON)
;============================================================
#:internalshell
ff 03 01 d1  # sub sp, sp, #64
fe 03 00 f9  # str x30, [sp]
f3 07 00 f9  # str x19, [sp, #8]
f4 0b 00 f9  # str x20, [sp, #16]
f5 0f 00 f9  # str x21, [sp, #24]
f6 13 00 f9  # str x22, [sp, #32]
f7 17 00 f9  # str x23, [sp, #40]
f8 1b 00 f9  # str x24, [sp, #48]
f9 1f 00 f9  # str x25, [sp, #56]

    ; Pre-load stdin data using CMD18 (raspi3b only — SDHCI PIO)
    ; On virt, skip preload (uses per-sector VirtIO reads)
09 06 a8 d2  # movz x9, #0x4030, lsl #16
2a 55 40 f9  # ldr x10, [x9, #0xA8] # board_has_sdhci flag
0a 05 00 b4  # cbz x10, shell_loop # skip preload if no SDHCI
36 01 40 f9  # ldr x22, [x9, #0x00] # SDHCI base
    ; Read up to 16128 sectors (8MB) starting from stdin_sector into VA 0x42000000
34 19 40 f9  # ldr x20, [x9, #0x30] # stdin_sector
    ; Store buffer pointer in globals+0x78
    ; Set to buffer - 512 so first advance (triggered by offset=512) lands at buffer start
ea 3f a8 d2  # movz x10, #0x41FF, lsl #16
0a c0 9f f2  # movk x10, #0xFE00 # 0x42000000 - 512 = 0x41FFFE00
2a 3d 00 f9  # str x10, [x9, #0x78]
    ; Set stdin_offset to 512 to trigger first advance
0a 40 80 d2  # mov x10, #512
2a 1d 00 f9  # str x10, [x9, #0x38]
    ; CMD18: multi-block read
ea ff 9f d2  # movz w10, #0xFFFF
ca 32 00 b9  # str w10, [x22, #0x30]
0a 40 80 d2  # movz w10, #0x0200
ca 0a 00 79  # strh w10, [x22, #0x04] # block size = 512
0a e0 87 d2  # movz w10, #0x3F00
ca 0e 00 79  # strh w10, [x22, #0x06] # block count = 16128
8a da 77 d3  # lsl w10, w20, #9
ca 0a 00 b9  # str w10, [x22, #0x08] # arg = stdin_sector * 512
    ; CMD18 + multi-block + block count enable + read + auto CMD12
ca 06 80 d2  # movz w10, #0x0036
4a 47 a2 f2  # movk w10, #0x123A, lsl #16
ca 0e 00 b9  # str w10, [x22, #0x0C]
    ; PIO read all blocks
13 40 a8 d2  # movz x19, #0x4200, lsl #16 # buffer VA 0x42000000 (PA 0x02000000, slow but safe from file data)
17 e0 87 d2  # movz x23, #0x3F00 # 16128 blocks
#:preload_block
97 01 00 b4  # cbz x23, preload_done
    ; Wait BRR for this block
#:preload_brr
b2 01 00 94  # bl sdhci_read_status
4b 01 7b 92  # and w11, w10, #0x20
cb ff ff b4  # cbz w11, preload_brr
    ; Read 128 words for this block
14 10 80 d2  # mov x20, #128
#:preload_pio
cb 22 40 b9  # ldr w11, [x22, #0x20]
6b 02 00 b9  # str w11, [x19]
73 12 00 91  # add x19, x19, #4
94 06 00 d1  # sub x20, x20, #1
94 ff ff b5  # cbnz x20, preload_pio
f7 06 00 d1  # sub x23, x23, #1
f5 ff ff 17  # b preload_block
#:preload_done
    ; Advance stdin_sector past preloaded data for per-sector fallback
09 06 a8 d2  # movz x9, #0x4030, lsl #16
2a 19 40 f9  # ldr x10, [x9, #0x30] # stdin_sector
0b e0 87 d2  # movz x11, #0x3F00 # 16128
4a 01 0b 8b  # add x10, x10, x11
2a 19 00 f9  # str x10, [x9, #0x30] # stdin_sector += 16128
    ; Clear status
ea ff 9f d2  # movz w10, #0xFFFF
ca 32 00 b9  # str w10, [x22, #0x30]

#:shell_loop
92 fc ff 97  # bl read_stdin_byte
f3 03 00 aa  # mov x19, x0

53 02 00 b4  # cbz x19, shell_done

7f 2a 00 f1  # cmp x19, #0x0A
80 ff ff 54  # b.eq shell_loop
7f 36 00 f1  # cmp x19, #0x0D
40 ff ff 54  # b.eq shell_loop

7f 8e 00 f1  # cmp x19, #0x23
00 01 00 54  # b.eq shell_skip_comment

7f ce 01 f1  # cmp x19, #0x73
20 04 00 54  # b.eq handle_src

7f a2 01 f1  # cmp x19, #0x68
e0 0c 00 54  # b.eq handle_hex0

7f 9a 01 f1  # cmp x19, #0x66
80 02 00 54  # b.eq handle_flush

f2 00 00 14  # b handle_other_command

#:shell_skip_comment
