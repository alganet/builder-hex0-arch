e0 0d 80 d2  # mov x0, #0x6F
05 fc ff 97  # bl uart_putchar
c0 0d 80 d2  # mov x0, #0x6E
03 fc ff 97  # bl uart_putchar
a0 0c 80 d2  # mov x0, #0x65
01 fc ff 97  # bl uart_putchar
c0 05 80 d2  # mov x0, #0x2E
ff fb ff 97  # bl uart_putchar
40 01 80 d2  # mov x0, #0x0A
fd fb ff 97  # bl uart_putchar

1a 02 00 94  # bl flush_disk
4d fc ff 17  # b reboot

